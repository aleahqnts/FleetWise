@page "/set-password"
@layout LoginLayout
@using Microsoft.AspNetCore.Identity
@inject SessionService Session
@inject DriverDataService Data
@inject AuthApi Api
@inject NavigationManager Nav

<div class="login-bg">
    <img class="logo-img" src="images/fleetwise-logo.png" alt="RouteSync" />
    <p class="app-name"><span class="n1">Route</span><span class="n2">Sync</span></p>

    <div class="card">
        <h1>Set Password</h1>
        <p style="text-align:center;color:#6b7280;font-size:.9rem;margin:-4px 0 14px;">
            You're using a temporary password. Create your own to continue.
        </p>

        <div class="field">
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2" /><path d="M8 11V8a4 4 0 0 1 8 0v3" /></svg></span>
            <input type="@(showPwd ? "text" : "password")" placeholder="New password" autocomplete="new-password"
                   @bind="newPwd" @bind:event="oninput" />
            <button type="button" class="eye" @onclick="@(() => showPwd = !showPwd)">
                @if (showPwd)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-7 10-7c2 0 3.8.6 5.3 1.5M22 12s-3.5 7-10 7c-2 0-3.8-.6-5.3-1.5" /><path d="M3 3l18 18" /><circle cx="12" cy="12" r="3" /></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" /><circle cx="12" cy="12" r="3" /></svg>
                }
            </button>
        </div>

        <div class="field">
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2" /><path d="M8 11V8a4 4 0 0 1 8 0v3" /></svg></span>
            <input type="@(showPwd ? "text" : "password")" placeholder="Confirm new password" autocomplete="new-password"
                   @bind="confirmPwd" @bind:event="oninput" @onkeydown="OnKey" />
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="message">@message</div>
        }

        <button class="btn-signin" @onclick="Save" disabled="@busy">
            @(busy ? "Saving..." : "Save Password")
        </button>
    </div>
</div>

@code {
    private string newPwd = "";
    private string confirmPwd = "";
    private bool busy;
    private bool showPwd;
    private string? message;

    protected override void OnInitialized()
    {
        // Only reachable mid-session; bounce to login if somehow opened cold.
        if (!Session.IsLoggedIn) Nav.NavigateTo("/");
    }

    private async Task Save()
    {
        message = null;
        if (newPwd.Length < 6) { message = "Password too short (min 6)."; return; }
        if (newPwd == AuthService.TemporaryPassword) { message = "Choose a password different from the temporary one."; return; }
        if (newPwd != confirmPwd) { message = "Passwords don't match."; return; }

        busy = true;
        try
        {
            // Phase 7: server-side change via the edge fn (the temp password IS the
            // current one). Legacy on-device hashing only if the fn is unreachable.
            var r = await Api.ChangePasswordAsync(AuthService.TemporaryPassword, newPwd);
            if (r.Outcome == AuthApi.Outcome.Denied) { message = r.Message; return; }
            if (r.Outcome == AuthApi.Outcome.Unreachable)
            {
                var hasher = new PasswordHasher<UserModel>();
                var hash = hasher.HashPassword(new UserModel(), newPwd);
                await Data.UpdatePasswordAsync(Session.CurrentUser!.UserId, hash);
            }
            SecureStorage.Default.Remove("fw_must_change");
            Nav.NavigateTo("/home");
        }
        catch (Exception ex)
        {
            message = "Update failed. Check your connection and try again.";
            System.Diagnostics.Debug.WriteLine($"[SetPassword] {ex}");
        }
        finally { busy = false; }
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Save();
    }
}
