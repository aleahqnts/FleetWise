@page "/profile"
@implements IDisposable
@using Microsoft.AspNetCore.Identity
@inject SessionService Session
@inject DriverDataService Data
@inject AuthApi Api
@inject MessageWatch Watch
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (loading)
{
    <div class="page-skeleton">
        <div class="sk sk-card tall" style="height:170px"></div>
        <div class="sk sk-card" style="height:76px"></div>
        <div class="sk sk-card"></div>
        <div class="sk sk-card"></div>
    </div>
}
else if (user is null)
{
    <div class="profile"><p class="muted">Couldn't load profile.</p></div>
}
else
{
    <div class="profile">

        <div class="hero">
            <div class="hero-avatar">@Initials</div>
            <p class="hero-name">@Session.DisplayName</p>
            <div class="hero-tags">
                <span class="tag role">Driver</span>
                <span class="tag avail @(available ? "on" : "off")">
                    <span class="dot"></span>@(available ? "Available" : "Unavailable")
                </span>
            </div>
            <p class="hero-since">Driving with RouteSync since @user.CreatedAt.ToString("MMMM yyyy")</p>
        </div>

        <div class="stats">
            <div class="stat">
                <p class="stat-n">@tripsDone</p>
                <p class="stat-l">Trips</p>
            </div>
            <div class="stat mid">
                <p class="stat-n">@passengers.ToString("N0")</p>
                <p class="stat-l">Passengers</p>
            </div>
            <div class="stat">
                <p class="stat-n">@tripsThisMonth</p>
                <p class="stat-l">This month</p>
            </div>
        </div>

        <p class="psec">Account</p>
        <div class="pinfo">
            <div class="prow">
                <span class="pico blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg></span>
                <span class="pk">Email</span><span class="pv">@user.EmailAddress</span>
            </div>
            <div class="prow">
                <span class="pico green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.5 2.5 5-6"/></svg></span>
                <span class="pk">Status</span><span class="pv">@(user.AccountStatus ?? "—")</span>
            </div>
            <div class="prow">
                <span class="pico amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg></span>
                <span class="pk">Member since</span><span class="pv">@user.CreatedAt.ToString("MMM d, yyyy")</span>
            </div>
            @if (lastTripDate is not null)
            {
                <div class="prow">
                    <span class="pico teal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
                    <span class="pk">Last trip</span><span class="pv">@lastTripDate.Value.ToString("MMM d, yyyy")</span>
                </div>
            }
        </div>

        <p class="psec">Settings</p>

        <button class="popt" @onclick="@(() => { showInfoForm = !showInfoForm; if (showInfoForm) showPwdForm = false; })">
            <span class="popt-left">
                <span class="pico teal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.5-6 8-6s8 2 8 6"/></svg></span>
                <span>Personal Information</span>
            </span>
            <span class="chev @(showInfoForm ? "open" : "")">&#8250;</span>
        </button>
        @if (showInfoForm)
        {
            <div class="pform expanded">
                <label>Contact number</label>
                <input value="@contact" @oninput="OnContactInput" inputmode="numeric" maxlength="13" placeholder="0917 123 4567" />
                @if (contact.Length > 0 && !PhoneValid(contact))
                {
                    <p class="err-msg">Format: 09XX XXX XXXX</p>
                }
                <label>Address</label>
                <input @bind="address" placeholder="Home address" />
                <label>Emergency contact name</label>
                <input @bind="emName" placeholder="Full name" />
                <label>Emergency contact number</label>
                <input value="@emNumber" @oninput="OnEmNumberInput" inputmode="numeric" maxlength="13" placeholder="0917 123 4567" />
                @if (emNumber.Length > 0 && !PhoneValid(emNumber))
                {
                    <p class="err-msg">Format: 09XX XXX XXXX</p>
                }

                @if (!string.IsNullOrEmpty(profileMsg))
                {
                    <p class="@(profileOk ? "ok-msg" : "err-msg")">@profileMsg</p>
                }
                <button class="psave" @onclick="SaveProfile" disabled="@savingProfile">
                    @(savingProfile ? "Saving..." : "Save Changes")
                </button>
            </div>
        }

        <button class="popt" @onclick="@(() => { showPwdForm = !showPwdForm; if (showPwdForm) showInfoForm = false; })">
            <span class="popt-left">
                <span class="pico navy"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></span>
                <span>Change Password</span>
            </span>
            <span class="chev @(showPwdForm ? "open" : "")">&#8250;</span>
        </button>
        @if (showPwdForm)
        {
            <div class="pform expanded">
                <input type="password" @bind="curPwd" placeholder="Current password" />
                <input type="password" @bind="newPwd" placeholder="New password" />
                <input type="password" @bind="confirmPwd" placeholder="Confirm new password" />

                @if (!string.IsNullOrEmpty(pwdMsg))
                {
                    <p class="@(pwdOk ? "ok-msg" : "err-msg")">@pwdMsg</p>
                }
                <button class="psave" @onclick="ChangePassword" disabled="@savingPwd">
                    @(savingPwd ? "Updating..." : "Update Password")
                </button>
            </div>
        }

        <button class="plogout" @onclick="@(() => showLogoutConfirm = true)">Log out</button>

        <p class="pver">RouteSync Driver</p>
    </div>

    @if (showLogoutConfirm)
    {
        <div class="overlay">
            <div class="ua-modal">
                <h2>Log out?</h2>
                <p class="lo-sub">You'll stop receiving assignments and messages until you log back in.</p>
                <div class="lo-actions">
                    <button class="lo-cancel" @onclick="@(() => showLogoutConfirm = false)">Cancel</button>
                    <button class="lo-confirm" @onclick="Logout">Log out</button>
                </div>
            </div>
        </div>
    }
}

@code {
    private bool loading = true;
    private UserModel? user;

    private bool available;
    private int tripsDone, tripsThisMonth, passengers;
    private DateTime? lastTripDate;

    private string contact = "", address = "", emName = "", emNumber = "";
    private bool savingProfile, profileOk;
    private string? profileMsg;

    private string curPwd = "", newPwd = "", confirmPwd = "";
    private bool savingPwd, pwdOk;
    private bool showPwdForm, showInfoForm, showLogoutConfirm;
    private string? pwdMsg;

    private string Initials
    {
        get
        {
            var parts = (Session.DisplayName ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries);
            return parts.Length switch
            {
                0 => "D",
                1 => parts[0][..1].ToUpper(),
                _ => $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/"); return; }

        await LoadUser();
        loading = false;
    }

    private async Task LoadUser()
    {
        var uid = Session.CurrentUser!.UserId;
        user = await Data.GetUserAsync(uid);
        if (user is not null)
        {
            contact = FormatPhone(Digits(user.ContactNumber));
            address = user.Address ?? "";
            emName = user.EmergencyContactName ?? "";
            emNumber = FormatPhone(Digits(user.EmergencyContactNumber));
        }

        // Real driving record, not decoration: completed trips, passengers served,
        // this month's runs. Failures degrade to zeros — profile still loads offline-ish.
        try
        {
            available = await Data.GetAvailabilityAsync(uid) == "Available";
            var trips = await Data.GetTripsForDriverAsync(uid);
            var done = trips.Where(t => t.TripStatus == "Completed").ToList();
            tripsDone = done.Count;
            passengers = done.Sum(t => t.TotalBoarded);
            tripsThisMonth = done.Count(t => t.Date.Year == DateTime.Today.Year && t.Date.Month == DateTime.Today.Month);
            lastTripDate = done.OrderByDescending(t => t.Date).FirstOrDefault()?.Date;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Profile.Stats] {ex}");
        }
    }

    private DotNetObjectReference<Profile>? _ptrRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ptrRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("ptr.set", _ptrRef);
        }
    }
    [JSInvokable] public async Task Refresh() { await LoadUser(); StateHasChanged(); }
    public void Dispose() => _ptrRef?.Dispose();

    private async Task SaveProfile()
    {
        profileMsg = null;
        if (contact.Length > 0 && !PhoneValid(contact)) { profileMsg = "Contact number must be 09XX XXX XXXX."; profileOk = false; return; }
        if (emNumber.Length > 0 && !PhoneValid(emNumber)) { profileMsg = "Emergency number must be 09XX XXX XXXX."; profileOk = false; return; }

        savingProfile = true;
        try
        {
            await Data.UpdateProfileAsync(user!.UserId, Nz(contact), Nz(address), Nz(emName), Nz(emNumber));
            profileMsg = "Changes saved."; profileOk = true;
        }
        catch (Exception ex)
        {
            profileMsg = "Save failed. Check your connection.";
            System.Diagnostics.Debug.WriteLine($"[Profile.Save] {ex}");
        }
        finally { savingProfile = false; }
    }

    private async Task ChangePassword()
    {
        pwdMsg = null;
        if (newPwd.Length < 6) { pwdMsg = "New password too short (min 6)."; pwdOk = false; return; }
        if (newPwd != confirmPwd) { pwdMsg = "New passwords don't match."; pwdOk = false; return; }

        savingPwd = true;
        try
        {
            // Phase 7: server-side verify + hash via the change-password edge fn.
            var r = await Api.ChangePasswordAsync(curPwd, newPwd);
            if (r.Outcome == AuthApi.Outcome.Denied)
            {
                pwdMsg = r.Message ?? "Current password is incorrect."; pwdOk = false; return;
            }
            if (r.Outcome == AuthApi.Outcome.Unreachable)
            {
                // Legacy fallback (fn not reachable / anon session): on-device verify + hash.
                // This path dies at the 7b cutover.
                var hasher = new PasswordHasher<UserModel>();
                var curHash = await Data.GetUserHashAsync(user!.UserId);
                if (curHash is null ||
                    hasher.VerifyHashedPassword(user, curHash, curPwd) == PasswordVerificationResult.Failed)
                {
                    pwdMsg = "Current password is incorrect."; pwdOk = false; return;
                }
                await Data.UpdatePasswordAsync(user.UserId, hasher.HashPassword(user, newPwd));
            }
            curPwd = newPwd = confirmPwd = "";
            pwdMsg = "Password updated."; pwdOk = true;
        }
        catch (Exception ex)
        {
            pwdMsg = "Update failed. Check your connection."; pwdOk = false;
            System.Diagnostics.Debug.WriteLine($"[Profile.Pwd] {ex}");
        }
        finally { savingPwd = false; }
    }

    private static string? Nz(string s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private void OnContactInput(ChangeEventArgs e) => contact = FormatPhone(Digits(e.Value?.ToString()));
    private void OnEmNumberInput(ChangeEventArgs e) => emNumber = FormatPhone(Digits(e.Value?.ToString()));

    private static string Digits(string? s)
    {
        var d = new string((s ?? "").Where(char.IsDigit).ToArray());
        return d.Length > 11 ? d[..11] : d;
    }

    // 09XX XXX XXXX  (groups of 4-3-4)
    private static string FormatPhone(string digits)
        => digits.Length <= 4 ? digits
         : digits.Length <= 7 ? $"{digits[..4]} {digits[4..]}"
         : $"{digits[..4]} {digits[4..7]} {digits[7..]}";

    private static bool PhoneValid(string formatted)
    {
        var d = new string(formatted.Where(char.IsDigit).ToArray());
        return d.Length == 11 && d.StartsWith("09");
    }

    private void Logout()
    {
        Watch.Stop();
        Session.Logout();
        Nav.NavigateTo("/");
    }
}
