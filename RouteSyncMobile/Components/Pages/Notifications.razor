@page "/notifications"
@implements IDisposable
@inject SessionService Session
@inject DriverDataService Data
@inject MessageWatch Watch
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (loading)
{
    <div class="page-skeleton">
        <div class="sk sk-line w50" style="height:24px; margin-bottom:20px"></div>
        <div class="sk sk-line w30"></div>
        <div class="sk sk-card"></div>
        <div class="sk sk-card"></div>
        <div class="sk sk-card"></div>
    </div>
}
else
{
    <div class="notif">
        <h1 class="ntitle">Notifications</h1>

        @if (!items.Any())
        {
            <p class="muted">No messages in the last 2 weeks.</p>
        }
        else
        {
            @foreach (var g in Grouped)
            {
                <h2 class="ngroup">@g.Key</h2>
                @foreach (var n in g)
                {
                    <div class="ncard @(IsUnread(n) ? "unread" : "")" @onclick="@(() => Toggle(n))">
                        <span class="nicon @IconClass(n)">
                            @switch (Aud(n))
                            {
                                case "all":
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11v2a1 1 0 0 0 1 1h2l4 4V6L6 10H4a1 1 0 0 0-1 1z" /><path d="M15 8a5 5 0 0 1 0 8" /></svg>
                                    break;
                                case "route":
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11z" /><circle cx="12" cy="10" r="2.5" /></svg>
                                    break;
                                default:
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                                    break;
                            }
                        </span>
                        <div class="nbody">
                            <div class="nhead">
                                <span class="nscope @ScopeClass(n)">@ScopeLabel(n)</span>
                                @if (IsHighPriority(n))
                                {
                                    <span class="nprio">High priority</span>
                                }
                            </div>
                            <p class="nt">@n.Subject</p>
                            @if (expandedId == n.MessageId)
                            {
                                <p class="np full">@n.Body</p>
                                <p class="ntime">@PhTime.Raw(n.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</p>
                            }
                            else
                            {
                                <p class="np">@n.Body</p>
                            }
                        </div>
                        @if (IsUnread(n))
                        {
                            <span class="ndot"></span>
                        }
                    </div>
                }
            }
        }
    </div>
}

@code {
    private bool loading = true;
    private List<MessageModel> items = new();

    private IEnumerable<IGrouping<string, MessageModel>> Grouped =>
        items.GroupBy(n => Label(PhTime.Raw(n.CreatedAt)));

    private static string Aud(MessageModel n) => (n.TargetAudience ?? "").ToLowerInvariant();

    // unread dot + mark-read only apply to driver-targeted msgs (1 recipient)
    private static bool IsUnread(MessageModel n) => Aud(n) == "driver" && !n.IsRead;

    private static bool IsHighPriority(MessageModel n) =>
        string.Equals(n.Priority, "high", StringComparison.OrdinalIgnoreCase);

    private static string ScopeLabel(MessageModel n) => Aud(n) switch
    {
        "all"   => "Broadcast · All drivers",
        "route" => "Route message",
        _       => "Direct message"
    };

    private static string ScopeClass(MessageModel n) => Aud(n) switch
    {
        "all"   => "scope-all",
        "route" => "scope-route",
        _       => "scope-driver"
    };

    // icon always matches audience (uniform); priority shown via the red tag
    private static string IconClass(MessageModel n) => Aud(n) switch
    {
        "all"   => "completed",
        "route" => "assigned",
        _       => "message"
    };

    private static string Label(DateTime d)
    {
        var dd = d.Date;
        if (dd == DateTime.Today) return "Today";
        if (dd == DateTime.Today.AddDays(-1)) return "Yesterday";
        return dd.ToString("MMMM d, yyyy");
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/"); return; }
        items = await Data.GetMessagesAsync(Session.CurrentUser!.UserId);
        loading = false;
        await Watch.RefreshNow();   // sync Watch cache w/ DB (authoritative is_read)
        Watch.MarkSeenNow();        // opening the tab clears broadcast/route from the badge
        _ = PollLoop();             // background: new messages appear without pull-to-refresh
    }

    // Silent re-fetch every 15s while the tab is open. New messages just appear; the
    // driver is looking at the list, so the badge is kept cleared too (MarkSeenNow).
    private readonly CancellationTokenSource pollCts = new();

    private async Task PollLoop()
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
            while (await timer.WaitForNextTickAsync(pollCts.Token))
            {
                try
                {
                    var fresh = await Data.GetMessagesAsync(Session.CurrentUser!.UserId);
                    await InvokeAsync(() =>
                    {
                        items = fresh;
                        Watch.MarkSeenNow();
                        StateHasChanged();
                    });
                }
                catch { /* background blip: keep showing the last good list */ }
            }
        }
        catch (OperationCanceledException) { /* page closed */ }
    }

    private long? expandedId;

    private async Task Toggle(MessageModel n)
    {
        expandedId = expandedId == n.MessageId ? null : n.MessageId;
        if (IsUnread(n))
        {
            n.IsRead = true;
            try { await Data.MarkMessageReadAsync(n.MessageId); await Watch.RefreshNow(); }
            catch (Exception ex) { System.Diagnostics.Debug.WriteLine($"[Msg.Read] {ex}"); }
        }
    }

    private DotNetObjectReference<Notifications>? _ptrRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ptrRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("ptr.set", _ptrRef);
        }
    }
    [JSInvokable] public async Task Refresh()
    {
        items = await Data.GetMessagesAsync(Session.CurrentUser!.UserId);
        Watch.MarkSeenNow();
        StateHasChanged();
    }
    public void Dispose()
    {
        pollCts.Cancel();
        pollCts.Dispose();
        _ptrRef?.Dispose();
    }
}
