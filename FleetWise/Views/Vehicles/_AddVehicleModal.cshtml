@*
    Add Vehicle modal — static UI (Block 15 wires the POST + dropdown data).
*@
<div class="modal fade vh-modal" id="addVehicleModal" tabindex="-1" aria-labelledby="addVehicleModalLabel" aria-hidden="true">
    <div class="modal-dialog vh-modal-sm">
        <div class="modal-content">
            <form method="post" action="#">
                <div class="modal-header">
                    <h5 class="modal-title vh-modal-title" id="addVehicleModalLabel">Add Vehicle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body vh-modal-body">
                    <div class="vh-section-header">Vehicle Profile</div>
                    <div class="vh-section-body">
                        <div class="vh-form-row">
                            <label>Vehicle ID:</label>
                            <input type="text" name="VehicleId" class="vh-form-input" placeholder="BUS-04" />
                        </div>
                        <div class="vh-form-row">
                            <label>Plate Number:</label>
                            <input type="text" name="PlateNumber" class="vh-form-input" placeholder="9302BA" />
                        </div>
                        <div class="vh-form-row">
                            <label>Vehicle Type:</label>
                            <div class="vh-select-wrap" style="width:100%;">
                                <select name="VehicleType" class="vh-form-input" style="appearance:none;">
                                    <option>Bus</option>
                                    <option>Van</option>
                                </select>
                                <span class="vh-select-arrow">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                </span>
                            </div>
                        </div>
                        <div class="vh-form-row">
                            <label>Route:</label>
                            <div class="vh-select-wrap" style="width:100%;">
                                <select name="RouteId" class="vh-form-input" style="appearance:none;">
                                    <option>Route 01</option>
                                    <option>Route 02</option>
                                    <option>Route 03</option>
                                </select>
                                <span class="vh-select-arrow">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="vh-btn vh-btn--outline" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="vh-btn vh-btn--primary">Add Vehicle</button>
                </div>
            </form>
        </div>
    </div>
</div>
