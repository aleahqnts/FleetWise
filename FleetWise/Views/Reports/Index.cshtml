<!-- Chart.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
    // ── Mini line charts ── Replace data arrays with model binding when DB is ready
    const weekLabels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

    function miniLineChart(id, data, color) {
    new Chart(document.getElementById(id).getContext('2d'), {
    type: 'line',
    data: {
    labels: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    datasets: [{
    data: data,
    borderColor: color,
    borderWidth: 1.8,
    pointRadius: 3,
    pointBackgroundColor: '#fff',
    pointBorderColor: color,
    pointBorderWidth: 1.5,
    tension: 0.35,
    fill: false
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: { legend: { display: false }, tooltip: { enabled: false } },
    scales: {
    x: {
    display: true,
    grid: { display: false },
    border: { display: false },
    ticks: { font: { size: 10, family: 'Segoe UI' }, color: '#9AA5B4', maxRotation: 0 }
    },
    y: {
    display: true,
    position: 'left',
    grid: { color: '#F0F0F0' },
    border: { display: false },
    ticks: { font: { size: 10, family: 'Segoe UI' }, color: '#9AA5B4', maxTicksLimit: 5 },
    grace: '10%'
    }
    },
    layout: { padding: { left: 0, right: 4, top: 4, bottom: 0 } }
    }
    });
    }

    // Replace these arrays with Html.Raw(Json.Serialize(Model.PassengerWeekData)) etc.
    miniLineChart('passengerMiniChart', [1800, 2100, 1950, 2300, 2100, 2400, 1580], '#9B59B6');
    miniLineChart('revenueMiniChart',   [28000, 34000, 31000, 38000, 35000, 42000, 37680], '#4AADA8');

    // ── Bar chart: Top Routes by Passengers ──
    // Replace with Html.Raw(Json.Serialize(Model.RoutePassengerData)) when DB is ready
    new Chart(document.getElementById('passengerBarChart').getContext('2d'), {
    type: 'bar',
    data: {
    labels: ['Route 01', 'Route 02', 'Route 03'],
    datasets: [{
    data: [6250, 4850, 3880],
    backgroundColor: ['#7C6FE0', '#4AADA8', '#4DB6C4'],
    borderRadius: 6,
    borderSkipped: false
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
    legend: { display: false },
    tooltip: {
    backgroundColor: '#fff',
    titleColor: '#2D3748',
    bodyColor: '#2D3748',
    borderColor: '#E8ECF0',
    borderWidth: 1,
    padding: 10,
    callbacks: {
    label: (item) => ` ${item.parsed.y.toLocaleString()} passengers`
    }
    }
    },
    scales: {
    x: { grid: { display: false }, ticks: { font: { size: 11, family: 'Segoe UI' }, color: '#9AA5B4' } },
    y: { grid: { color: '#F0F0F0' }, ticks: { font: { size: 11, family: 'Segoe UI' }, color: '#9AA5B4' } }
    }
    }
    });
</script>

<style>
    :root {
    --rp-text: #2D3748;
    --rp-muted: #9AA5B4;
    --rp-border: #E8ECF0;
    --rp-bg: #F8F9FA;
    --rp-white: #FFFFFF;
    --rp-teal: #4AADA8;
    --rp-radius: 14px;
    --rp-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    /* ── Topbar filters ─────────────────────────────────────── */
    .rp-route-wrap, .rp-date-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    }

    .rp-filter-label {
    font-size: 0.88rem;
    font-family: 'Segoe UI', sans-serif;
    color: var(--rp-text);
    font-weight: 500;
    white-space: nowrap;
    }

    .rp-select-wrap {
    position: relative;
    display: flex;
    align-items: center;
    }

    .rp-select {
    appearance: none;
    padding: 6px 32px 6px 12px;
    border: 1.5px solid var(--rp-border);
    border-radius: 10px;
    font-size: 0.82rem;
    font-family: 'Segoe UI', sans-serif;
    color: var(--rp-text);
    background: var(--rp-bg);
    cursor: pointer;
    outline: none;
    font-weight: 500;
    }

    .rp-select-arrow {
    position: absolute;
    right: 10px;
    pointer-events: none;
    color: var(--rp-text);
    display: flex;
    }

    .rp-input-wrap {
    position: relative;
    }

    .rp-date-input {
    padding: 6px 12px;
    border: 1.5px solid var(--rp-border);
    border-radius: 10px;
    font-size: 0.82rem;
    font-family: 'Segoe UI', sans-serif;
    color: var(--rp-text);
    background: var(--rp-bg);
    outline: none;
    cursor: pointer;
    }

    .rp-date-input:focus {
    border-color: var(--rp-teal);
    }

    /* ── Page title ─────────────────────────────────────────── */
    .rp-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--rp-text);
    font-family: 'Segoe UI', sans-serif;
    margin-bottom: 20px;
    }

    /* ── Stat grid ──────────────────────────────────────────── */
    .rp-stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 20px;
    }

    .rp-stat-card {
    background: var(--rp-white);
    border: 1px solid var(--rp-border);
    border-radius: var(--rp-radius);
    padding: 20px 22px;
    box-shadow: var(--rp-shadow);
    }

    .rp-stat-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    }

    .rp-stat-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    }

    .rp-stat-icon--green {
    background: #E8F8EE;
    color: #27AE60;
    }

    .rp-stat-icon--red {
    background: #FEECEC;
    color: #E74C3C;
    }

    .rp-stat-icon--blue {
    background: #EAF3FF;
    color: #3B82F6;
    }

    .rp-stat-icon--pink {
    background: #FDF0F8;
    color: #D63384;
    }

    .rp-stat-label {
    font-size: 0.82rem;
    font-family: 'Segoe UI', sans-serif;
    color: var(--rp-muted);
    font-weight: 500;
    }

    .rp-stat-value {
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--rp-text);
    font-family: 'Segoe UI', sans-serif;
    line-height: 1.1;
    }

    .rp-stat-sub {
    font-size: 0.78rem;
    color: var(--rp-muted);
    font-family: 'Segoe UI', sans-serif;
    margin-top: 4px;
    }

    .rp-stat-delta {
    font-size: 0.78rem;
    font-family: 'Segoe UI', sans-serif;
    margin-top: 5px;
    }

    .rp-delta--up {
    color: #27AE60;
    }

