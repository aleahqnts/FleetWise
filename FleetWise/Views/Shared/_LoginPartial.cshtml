<ul class="navbar-nav">
@if (User.Identity?.IsAuthenticated ?? false)
{
    <li class="nav-item">
        <span class="nav-link text-dark">Hello @User.Identity!.Name!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-controller="Home" asp-action="Logout" method="post">
            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Login</a>
    </li>
}
</ul>
