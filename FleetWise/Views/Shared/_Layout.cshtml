<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FleetWise</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FleetWise.styles.css" asp-append-version="true" />
</head>
<body>

    <div class="app-layout">

        <div class="app-body">

            <!-- SIDEBAR -->
            @await Html.PartialAsync("_Sidebar")

            <!-- MAIN AREA -->
            <div class="main-area">

                <!-- TOP BAR (now inside main area) -->
                <header class="topbar">
                    <div class="container-fluid d-flex align-items-center gap-5">
                        @await RenderSectionAsync("TopbarContent", required: false)
                        <div>
                            <!-- optional user/profile/actions -->
                        </div>
                    </div>
                </header>

                <!-- PAGE CONTENT -->
                <main class="main-content">
                    @RenderBody()
                </main>

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
