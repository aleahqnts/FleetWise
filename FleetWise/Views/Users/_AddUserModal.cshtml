@model AddUserViewModel

<div class="modal fade us-modal" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog us-modal-sm">
        <div class="modal-content">
            <form asp-action="Create" asp-controller="Users" method="post">
                <div class="modal-header">
                    <h5 class="modal-title us-modal-title" id="addUserModalLabel">Add New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body us-modal-body">
                    <div class="us-section-header">Profile</div>
                    <div class="us-section-body">
                        <div class="us-form-row">
                            <label asp-for="FirstName">First Name:</label>
                            <input asp-for="FirstName" class="us-form-input" />
                            <span asp-validation-for="FirstName" class="us-field-error"></span>
                        </div>
                        <div class="us-form-row">
                            <label asp-for="MiddleName">Middle Name:</label>
                            <input asp-for="MiddleName" class="us-form-input" />
                            <span asp-validation-for="MiddleName" class="us-field-error"></span>
                        </div>
                        <div class="us-form-row">
                            <label asp-for="LastName">Last Name:</label>
                            <input asp-for="LastName" class="us-form-input" />
                            <span asp-validation-for="LastName" class="us-field-error"></span>
                        </div>
                        <div class="us-form-row">
                            <label asp-for="Email">Email Address:</label>
                            <input asp-for="Email" class="us-form-input" />
                            <span asp-validation-for="Email" class="us-field-error"></span>
                        </div>
                        <div class="us-form-row">
                            <label asp-for="InitialPassword">Initial Password:</label>
                            <input asp-for="InitialPassword" id="auGeneratedPassword" readonly class="us-form-input us-form-input--mono" />
                            <span class="us-field-hint">Auto-generated Password</span>
                            <span asp-validation-for="InitialPassword" class="us-field-error"></span>
                        </div>
                    </div>
                    <div class="us-section-header">Role Assignment</div>
                    <div class="us-section-body">
                        <div class="us-form-row">
                            <label asp-for="RoleId">Role:</label>
                            <select asp-for="RoleId" class="us-form-input" asp-items="(List<SelectListItem>)ViewBag.Roles">
                                <option value="0">Select role…</option>
                            </select>
                            <span class="us-field-hint">Permissions will be based on selected role.</span>
                            <span asp-validation-for="RoleId" class="us-field-error"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="us-btn us-btn--outline" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="us-btn us-btn--primary">Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>
