@model List<UserListItemViewModel>
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var roles = ViewBag.Roles as List<SelectListItem> ?? new List<SelectListItem>();
    var selectedRole = ViewBag.SelectedRole as string;
    var searchTerm = ViewBag.SearchTerm as string;
}

<!-- PAGE TITLE -->
<h2 class="us-title">Users</h2>

<!-- USERS TABLE CARD -->
<div class="us-card">
    <div class="us-toolbar">
        <form method="get" class="us-filters">
            <div class="us-select-wrap">
                <select name="role" class="us-select" onchange="this.form.submit()">
                    <option value="">All Roles</option>
                    @foreach (var r in roles)
                    {
                        <option value="@r.Value" selected="@(r.Value == selectedRole)">@r.Text</option>
                    }
                </select>
                <span class="us-select-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </span>
            </div>

            <div class="us-search-wrap">
                <span class="us-search-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
                         stroke="#9AA5B4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                </span>
                <input type="text" name="search" value="@searchTerm" class="us-search-input" placeholder="Search by name or email" />
            </div>
        </form>

        <div class="us-actions">
            <button type="button" class="us-btn us-btn--outline" disabled>Manage Roles</button>
            <button type="button" class="us-btn us-btn--primary" disabled>+ Add User</button>
        </div>
    </div>

    <div class="us-table-wrap">
        <table class="us-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="us-empty">No users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model)
                    {
                        var statusClass = user.AccountStatus == "Activated" ? "us-status--active" : "us-status--inactive";
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.RoleName</td>
                            <td><span class="us-status @statusClass">@user.AccountStatus</span></td>
                            <td><button type="button" class="us-btn-edit" disabled>Edit</button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    :root {
        --us-teal: #4AADA8;
        --us-teal-light: #E8F6F5;
        --us-text: #2D3748;
        --us-muted: #9AA5B4;
        --us-border: #E8ECF0;
        --us-bg: #F8F9FA;
        --us-white: #FFFFFF;
        --us-radius: 14px;
        --us-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    /* ── Page title ─────────────────────────────────────────── */
    .us-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--us-text);
        font-family: 'Segoe UI', sans-serif;
        margin-bottom: 20px;
    }

    /* ── Card ───────────────────────────────────────────────── */
    .us-card {
        background: var(--us-white);
        border: 1px solid var(--us-border);
        border-radius: var(--us-radius);
        padding: 20px 22px;
        box-shadow: var(--us-shadow);
    }

    /* ── Toolbar ────────────────────────────────────────────── */
    .us-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .us-filters {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .us-select-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .us-select {
        appearance: none;
        padding: 7px 32px 7px 14px;
        border: 1.5px solid var(--us-border);
        border-radius: 10px;
        font-size: 0.85rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--us-text);
        background: var(--us-bg);
        cursor: pointer;
        outline: none;
        font-weight: 500;
    }

    .us-select-arrow {
        position: absolute;
        right: 10px;
        pointer-events: none;
        color: var(--us-text);
        display: flex;
    }

    .us-search-wrap {
        position: relative;
    }

    .us-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        align-items: center;
    }

    .us-search-input {
        width: 260px;
        padding: 7px 14px 7px 36px;
        border: 1.5px solid var(--us-border);
        border-radius: 10px;
        font-size: 0.85rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--us-text);
        background: var(--us-bg);
        outline: none;
        transition: border-color 180ms;
    }

    .us-search-input:focus {
        border-color: var(--us-teal);
    }

    /* ── Action buttons ─────────────────────────────────────── */
    .us-actions {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .us-btn {
        padding: 8px 18px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-family: 'Segoe UI', sans-serif;
        font-weight: 600;
        cursor: pointer;
        border: 1.5px solid var(--us-border);
        transition: all 180ms;
        white-space: nowrap;
    }

    .us-btn--outline {
        background: var(--us-white);
        color: var(--us-text);
    }

    .us-btn--primary {
        background: var(--us-teal);
        border-color: var(--us-teal);
        color: #fff;
    }

    .us-btn:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    /* ── Table ──────────────────────────────────────────────── */
    .us-table-wrap {
        overflow-x: auto;
    }

    .us-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
        font-size: 0.875rem;
    }

    .us-table thead tr {
        border-bottom: 1.5px solid var(--us-border);
    }

    .us-table th {
        padding: 10px 14px;
        text-align: left;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--us-muted);
        white-space: nowrap;
    }

    .us-table td {
        padding: 13px 14px;
        color: var(--us-text);
        border-bottom: 1px solid var(--us-border);
        vertical-align: middle;
    }

    .us-table tbody tr:last-child td {
        border-bottom: none;
    }

    .us-table tbody tr:hover {
        background: #FAFBFC;
    }

    .us-empty {
        text-align: center;
        color: var(--us-muted);
        padding: 24px 14px;
    }

    /* ── Status badges ──────────────────────────────────────── */
    .us-status {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        font-family: 'Segoe UI', sans-serif;
        white-space: nowrap;
    }

    .us-status--active {
        background: #E8F8EE;
        color: #27AE60;
    }

    .us-status--inactive {
        background: #F1F2F4;
        color: #9AA5B4;
    }

    /* ── Edit button ────────────────────────────────────────── */
    .us-btn-edit {
        padding: 6px 18px;
        border: 1.5px solid var(--us-border);
        border-radius: 8px;
        background: var(--us-white);
        font-size: 0.8rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--us-text);
        cursor: pointer;
        font-weight: 500;
        transition: border-color 180ms, background 180ms;
    }

    .us-btn-edit:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    /* ── Responsive ─────────────────────────────────────────── */
    @@media (max-width: 768px) {
        .us-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .us-filters {
            flex-direction: column;
            align-items: stretch;
        }

        .us-search-input {
            width: 100%;
        }

        .us-actions {
            justify-content: flex-end;
        }
    }
</style>
