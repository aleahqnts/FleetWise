@section TopbarContent {
    <div class="rp-route-wrap">
        <span class="rp-filter-label">Route:</span>
        <div class="rp-select-wrap">
            <select class="rp-select" id="routeFilter">
                <option value="0">All Routes</option>
                @foreach (var route in Model.Routes)
                {
                    <option value="@route.RouteId">@route.RouteName</option>
                }
            </select>
            <span class="rp-select-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </span>
        </div>
    </div>

    <div class="rp-status-wrap">
        <span class="rp-filter-label">Status:</span>
        <div class="rp-select-wrap">
            <select class="rp-select" id="statusFilter">
                <option value="">All</option>
                <option value="Active">Active</option>
                <option value="Not Yet Started">Not Yet Started</option>
                <option value="Pending">Pending</option>
                <option value="Assignment Issue">Assignment Issue</option>
                <option value="Missed">Missed</option>
                <option value="Completed">Completed</option>
            </select>
            <span class="rp-select-arrow">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </span>
        </div>
    </div>
}

<script>
    function applyFilters() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        const routeId = document.getElementById('routeFilter').value;
        const status = document.getElementById('statusFilter').value;

        document.querySelectorAll('.dp-route-card').forEach(card => {
            const cardRouteId = card.dataset.routeId;
            const routeMatches = routeId === '0' || routeId === '' || cardRouteId === routeId;

            // Routes with no trips today
            const emptyRow = card.querySelector('.dp-empty-row');
            if (emptyRow) {
                const showEmpty = routeMatches && status === '' && q === '';
                card.style.display = showEmpty ? '' : 'none';
                emptyRow.style.display = showEmpty ? '' : 'none';
                return;
            }

            const rows = Array.from(card.querySelectorAll('.dp-trip-row'));
            let anyVisibleInCard = false;

            // Group rows by shift id, preserving order
            const shiftGroups = {};
            const shiftOrder = [];
            rows.forEach(row => {
                const sid = row.dataset.shiftId;
                if (!shiftGroups[sid]) {
                    shiftGroups[sid] = [];
                    shiftOrder.push(sid);
                }
                shiftGroups[sid].push(row);
            });

            shiftOrder.forEach(sid => {
                const groupRows = shiftGroups[sid];

                // Step 1: Always restore shift cell to the first row of the group
                // so we start from a clean, predictable state each time filters run.
                let shiftCell = null;
                groupRows.forEach(row => {
                    const cell = row.querySelector('.dp-shift-cell');
                    if (cell) shiftCell = cell;
                });
                if (shiftCell && !groupRows[0].querySelector('.dp-shift-cell')) {
                    groupRows[0].insertBefore(shiftCell, groupRows[0].firstChild);
                }

                // Step 2: Determine visibility for each row
                const visibility = groupRows.map(row => {
                    const rowStatus = row.dataset.tripStatus || '';
                    const statusMatches = status === '' || rowStatus === status;
                    const textMatches = q === '' || row.textContent.toLowerCase().includes(q);
                    return routeMatches && statusMatches && textMatches;
                });

                const visibleCount = visibility.filter(Boolean).length;

                if (visibleCount === 0) {
                    // Hide all rows in this shift, including the one holding the shift cell
                    groupRows.forEach(row => { row.style.display = 'none'; });
                    return;
                }

                anyVisibleInCard = true;

                // Step 3: Move shift cell to first visible row if it isn't already there
                const firstVisibleIndex = visibility.indexOf(true);
                const firstVisibleRow = groupRows[firstVisibleIndex];
                if (shiftCell && !firstVisibleRow.querySelector('.dp-shift-cell')) {
                    firstVisibleRow.insertBefore(shiftCell, firstVisibleRow.firstChild);
                }

                // Step 4: Update rowspan to match visible count
                if (shiftCell) shiftCell.setAttribute('rowspan', visibleCount);

                // Step 5: Show/hide each row
                groupRows.forEach((row, idx) => {
                    row.style.display = visibility[idx] ? '' : 'none';
                });
            });

            card.style.display = (routeMatches && anyVisibleInCard) ? '' : 'none';
        });
    }

    function filterRows() { applyFilters(); }

    function handleReassignClick(btn) {
        const status = btn.dataset.status;
        if (status === 'Active' || status === 'Completed') return;
        openReassignModal(btn.dataset.tripId);
    }

    document.getElementById('routeFilter').addEventListener('change', applyFilters);
    document.getElementById('statusFilter').addEventListener('change', applyFilters);
</script>

