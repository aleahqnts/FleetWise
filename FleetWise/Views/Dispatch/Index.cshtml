@model FleetWise.ViewModels.DispatchViewModel
@{
    ViewData["Title"] = "Dispatch";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- PAGE TITLE -->
<div class="dp-title-row">
    <h2 class="rp-title">Dispatch</h2>
    <div class="dp-date-nav">
        <a class="dp-date-arrow" href="@Url.Action("Index", new { date = Model.PrevDate })" title="Previous day">
            <i class="ti ti-chevron-left"></i>
        </a>
        <span class="dp-date-badge" title="One operational day runs 6:00 AM to 5:59 AM the next morning">
            <i class="ti ti-calendar-event"></i>
            <span class="dp-cycle-main">@Model.ScheduleDate.ToString("ddd, MMM d")</span>
            <span class="dp-cycle-range">6:00 AM → @Model.ScheduleDate.AddDays(1).ToString("MMM d") 5:59 AM</span>
        </span>
        <a class="dp-date-arrow" href="@Url.Action("Index", new { date = Model.NextDate })" title="Next day">
            <i class="ti ti-chevron-right"></i>
        </a>
        @if (!Model.IsToday)
        {
            <a class="dp-date-today" href="@Url.Action("Index")">Today</a>
        }
    </div>
</div>

<!-- STAT CARDS -->
<div class="dp-stat-grid" id="dpStats">

    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <span class="rp-stat-icon rp-stat-icon--green">
                <i class="ti ti-bus"></i>
            </span>
            <span class="rp-stat-label">Active Trips</span>
        </div>
        <div class="rp-stat-value">@Model.ActiveTrips</div>
        <div class="rp-stat-sub">Today</div>
    </div>

    <div class="rp-stat-card">
        <div class="rp-stat-header">
            <span class="rp-stat-icon rp-stat-icon--amber">
                <i class="ti ti-clock-pause"></i>
            </span>
            <span class="rp-stat-label">Trips Not Started</span>
        </div>
        <div class="rp-stat-value">@Model.TripsNotStarted</div>
        <div class="rp-stat-sub">Awaiting departure</div>
    </div>

    <div class="rp-stat-card @(Model.UnassignedTrips > 0 ? "dp-card-click" : "")"
         @(Model.UnassignedTrips > 0 ? "onclick=dpHighlightIssues()" : "")>
        <div class="rp-stat-header">
            <span class="rp-stat-icon rp-stat-icon--red">
                <i class="ti ti-alert-circle"></i>
            </span>
            <span class="rp-stat-label">Assignment Issues</span>
        </div>
        <div class="rp-stat-value">@Model.UnassignedTrips</div>
        <div class="rp-stat-sub">@(Model.UnassignedTrips > 0 ? "Tap to view affected trips" : "Flagged bus or unavailable driver")</div>
    </div>

    <div class="rp-stat-card dp-side-card">
        <div class="dp-side-row">
            <a class="dp-side-link" href="/Vehicles?status=Flagged" title="View flagged vehicles">
                <div class="rp-stat-label">Flagged Vehicles</div>
                <div class="rp-stat-value dp-side-value--red">@Model.FlaggedVehicles</div>
                @if (Model.FlaggedVehicles > 0)
                {
                    <div class="dp-side-view">View &#8250;</div>
                }
            </a>
            <div>
                <div class="rp-stat-label">Unavailable Drivers</div>
                <div class="rp-stat-value dp-side-value--red">@Model.UnavailableDrivers</div>
            </div>
        </div>
    </div>

</div>

<!-- TOOLBAR -->
<div class="dp-toolbar">
    <button class="dp-btn-primary" onclick="openAddTripModal()">
        <i class="ti ti-plus"></i> Add Trip
    </button>
    <button class="dp-btn-secondary" onclick="openBroadcastModal()"><i class="ti ti-speakerphone"></i> Broadcast Message</button>
    <a class="dp-btn-secondary" href="/Schedule" style="text-decoration:none;"><i class="ti ti-calendar-week"></i> Edit Schedule</a>
    <div class="dp-search-wrap">
        <i class="ti ti-search dp-search-icon"></i>
        <input type="text" id="searchInput" class="dp-search-input" placeholder="Search…" oninput="filterRows()" />
    </div>
    <button class="dp-btn-refresh" id="dpRefreshBtn" onclick="dpRefresh(true)" title="Refresh this page only">
        <i class="ti ti-refresh"></i> Refresh
    </button>
    <span class="dp-updated" id="dpUpdated" title="Auto-refreshes every 30 seconds"></span>
</div>

<!-- ROUTE BLOCKS -->
<div id="dpRoutes">
@foreach (var route in Model.Routes)
{
    <div class="rp-card rp-card--table dp-route-card" data-route-id="@route.RouteId">
        <div class="dp-route-header">
            <span class="dp-route-name">@route.RouteName</span>
            <div class="dp-route-header-right">
                @if (route.NeedsAssignment)
                {
                    <span class="dp-needs-badge"><span class="dp-needs-dot"></span> Needs Reassignment</span>
                }
                <button class="dp-btn-route-msg" onclick="openRouteMessageModal(@route.RouteId, '@route.RouteName')"><i class="ti ti-message-2"></i> Route Message</button>
            </div>
        </div>

        <div class="rp-table-wrap">
            <table class="rp-table dp-table">
                <colgroup>
                    <col class="dp-col-shift" />
                    <col class="dp-col-bus" />
                    <col class="dp-col-driver" />
                    <col class="dp-col-status" />
                    <col class="dp-col-actions" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Shift</th>
                        <th>Bus ID</th>
                        <th>Driver</th>
                        <th>Trip Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!route.Shifts.Any())
                    {
                        <tr class="dp-trip-row dp-empty-row" data-trip-status="">
                            <td colspan="5" class="dp-empty-cell">No trips scheduled for this operational day.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var shift in route.Shifts)
                        {
                            var shiftTrips = shift.Trips;
                            var shiftId = $"{route.RouteId}-{shift.ShiftType}".Replace(" ", "-");

                            @for (int i = 0; i < shiftTrips.Count; i++)
                            {
                                var trip = shiftTrips[i];

                                // Operational/readiness dot — trip-derived, so a bus used by
                                // another shift can never bleed a stale colour here. A missed
                                // trip is grey (not green), completed is slate. Roadworthiness
                                // shows as a SEPARATE flag marker, never overwriting this dot.
                                var (vDotClass, vTooltip) =
                                    trip.TripStatus == "Missed" ? ("dp-dot--missed", "Missed — bus not used") :
                                    trip.VehicleStatus switch
                                    {
                                        "On Trip" => ("dp-dot--green", "On trip"),
                                        "Completed" => ("dp-dot--slate", "Trip completed"),
                                        "Ready to Deploy" => ("dp-dot--blue", "Ready to deploy"),
                                        "Flagged" => ("dp-dot--red", "Flagged on inspection"),
                                        "Pending" => ("dp-dot--yellow", "Pending checklist"),
                                        _ => ("dp-dot--gray", trip.VehicleStatus)
                                    };

                                // Driver status icon
                                var (dDotClass, dTooltip) = trip.DriverStatus switch
                                {
                                    "On Trip" => ("dp-dot--green", "On trip"),
                                    "Available" => ("dp-dot--blue", "Available"),
                                    "Unavailable" => ("dp-dot--red", "Unavailable"),
                                    _ => ("dp-dot--gray", trip.DriverStatus)
                                };

                                // Trip status badge
                                var (badgeClass, badgeLabel) = trip.TripStatus switch
                                {
                                    "Active" => ("dp-badge--active", "Active"),
                                    "Not Yet Started" => ("dp-badge--not-started", "Not Yet Started"),
                                    "Pending" => ("dp-badge--pending", "Pending"),
                                    "Assignment Issue" => ("dp-badge--issue", "Assignment Issue"),
                                    "Missed" => ("dp-badge--missed", "Missed"),
                                    "Completed" => ("dp-badge--completed", "Completed"),
                                    _ => ("dp-badge--completed", trip.TripStatus)
                                };

                                <tr class="dp-trip-row"
                                    data-trip-status="@trip.TripStatus"
                                    data-shift-id="@shiftId">
                                    @if (i == 0)
                                    {
                                        <td class="dp-shift-cell" rowspan="@shiftTrips.Count">
                                            @shift.ShiftType<br />
                                            <span class="dp-shift-time">(@shift.ShiftStartTime – @shift.ShiftEndTime@(shift.IsOvernight ? " +1" : ""))</span>
                                            @if (shift.IsOvernight)
                                            {
                                                <span class="dp-overnight-tag" title="Ends the next morning">overnight</span>
                                            }
                                        </td>
                                    }
                                    <td>
                                        <div class="dp-status-wrap">
                                            <span class="dp-status-dot @vDotClass"></span>
                                            <span class="dp-tooltip">@vTooltip</span>
                                            <strong>@trip.VehicleId</strong>
                                            <span class="rp-plate">| @trip.PlateNumber</span>
                                            @if (trip.Flagged)
                                            {
                                                <span class="dp-flag" title="Flagged on inspection — see Trip Detail / Vehicles"><i class="ti ti-flag-filled"></i></span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="dp-status-wrap">
                                            <span class="dp-status-dot @dDotClass"></span>
                                            <span class="dp-tooltip">@dTooltip</span>
                                            @trip.DriverName
                                        </div>
                                    </td>
                                    <td>
                                        @if (trip.TripStatus == "Assignment Issue" && !string.IsNullOrEmpty(trip.AssignmentIssueReason))
                                        {
                                            <span class="dp-badge @badgeClass dp-badge--hint" data-tip="@trip.AssignmentIssueReason">@badgeLabel</span>
                                        }
                                        else
                                        {
                                            <span class="dp-badge @badgeClass">@badgeLabel</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="dp-actions-cell">
                                            <button class="rp-btn-view" onclick="openTripModal('@trip.TripId')">View</button>
                                            <button class="dp-btn-reassign"
                                                    data-trip-id="@trip.TripId"
                                                    data-status="@trip.TripStatus"
                                                    onclick="handleReassignClick(this)"
                                                @(trip.TripStatus == "Active" || trip.TripStatus == "Completed" || trip.TripStatus == "Missed" ? "disabled" : "")>
                                                Reassign
                                            </button>
                                            <button class="dp-btn-msg" title="Message" onclick="openTripMessageModal('@trip.TripId', '@trip.VehicleId', '@trip.DriverName')"><i class="ti ti-message"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
</div><!-- /dpRoutes -->

<!-- spacer so content above isn't hidden behind the fixed legend bar -->
<div style="height:64px;"></div>

<!-- LEGEND -->
<div class="rp-card dp-legend-card">
    <div class="dp-legend-row">
        <span class="dp-legend-label">Legend</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--green"></span> On trip</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--blue"></span> Bus: ready to deploy &nbsp;|&nbsp; Driver: available</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--yellow"></span> Bus: pending checklist</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--red"></span> Bus: flagged &nbsp;|&nbsp; Driver: unavailable</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--slate"></span> Trip completed</span>
        <span class="dp-legend-item"><span class="dp-status-dot dp-dot--missed"></span> Missed Trip</span>
    </div>
</div>

<!-- Shared message popup (Add Trip / Reassign conflicts) -->
<div id="dp-msg-modal" class="dp-msg-overlay" style="display:none;">
    <div class="dp-msg-box">
        <div class="dp-msg-head">
            <span class="dp-msg-ico">&#9888;</span>
            <h3 id="dp-msg-title">Schedule conflict</h3>
        </div>
        <ul id="dp-msg-list" class="dp-msg-list"></ul>
        <button class="dp-msg-btn" onclick="dpCloseMsg()">Got it</button>
    </div>
</div>

<script>
    function dpShowMsg(messages, title) {
        document.getElementById('dp-msg-title').textContent = title || 'Schedule conflict';
        document.getElementById('dp-msg-list').innerHTML =
            (Array.isArray(messages) ? messages : [messages]).map(m => `<li>${m}</li>`).join('');
        document.getElementById('dp-msg-modal').style.display = 'flex';
    }
    function dpCloseMsg() { document.getElementById('dp-msg-modal').style.display = 'none'; }

    function dpHighlightIssues() {
        const rows = document.querySelectorAll('.dp-trip-row[data-trip-status="Assignment Issue"]');
        document.querySelectorAll('.dp-row-flag').forEach(r => r.classList.remove('dp-row-flag'));
        if (!rows.length) return;
        rows.forEach(r => r.classList.add('dp-row-flag'));
        rows[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // ── Assignment-Issue hover popup ───────────────────────────
    // Floating element on document body (delegated, immune to the route card's
    // overflow:hidden). A live-refresh can swap the hovered badge out from under the
    // cursor so mouseout never fires — a mousemove fallback kills the ghost.
    (function () {
        let tip = null, current = null;
        function ensure() {
            if (!tip) {
                tip = document.createElement('div');
                tip.className = 'dp-tip';
                document.body.appendChild(tip);
            }
            return tip;
        }
        function show(badge) {
            const text = badge.getAttribute('data-tip');
            if (!text) return;
            current = badge;
            ensure().textContent = text;
            const r = badge.getBoundingClientRect();
            tip.style.opacity = '0';
            tip.classList.add('dp-tip--show');
            const tw = tip.offsetWidth, th = tip.offsetHeight;   // measure after text set
            let left = r.left + r.width / 2 - tw / 2;
            left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
            tip.style.left = left + 'px';
            tip.style.top = (r.top - th - 9) + 'px';
            tip.style.opacity = '1';
        }
        function hide() {
            current = null;
            if (tip) { tip.remove(); tip = null; }   // fully remove -> no ghost
        }
        document.addEventListener('mouseover', e => {
            const b = e.target.closest && e.target.closest('.dp-badge--hint');
            if (b && b !== current) show(b);
        });
        // Fallback: any pointer move that isn't over the current badge clears it.
        document.addEventListener('mousemove', e => {
            if (!current) return;
            const b = e.target.closest && e.target.closest('.dp-badge--hint');
            if (b !== current) hide();
        });
        window.addEventListener('scroll', hide, true);
    })();

    // ── Live refresh ───────────────────────────────────────────
    // Re-fetch THIS page (current date in the URL) and swap only the stats +
    // route blocks. No full browser reload, no SignalR. Manual button always
    // runs; the 30s auto-poll skips when a modal is open, the user is searching,
    // or the tab is hidden so it never yanks the view mid-action.
    let dpBusy = false;

    function dpAnyModalOpen() {
        return [...document.querySelectorAll('[class*="overlay"]')]
            .some(el => getComputedStyle(el).display !== 'none');
    }

    function dpStamp() {
        const el = document.getElementById('dpUpdated');
        if (el) el.textContent = 'Updated ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }

    async function dpRefresh(manual) {
        if (dpBusy) return;
        dpBusy = true;
        const btn = document.getElementById('dpRefreshBtn');
        if (manual && btn) btn.classList.add('spinning');
        try {
            const res = await fetch(window.location.href, { headers: { 'X-Requested-With': 'fetch' } });
            const html = await res.text();
            const doc = new DOMParser().parseFromString(html, 'text/html');
            ['dpStats', 'dpRoutes'].forEach(id => {
                const fresh = doc.getElementById(id);
                const cur = document.getElementById(id);
                if (fresh && cur) cur.innerHTML = fresh.innerHTML;
            });
            // Re-apply active search filter to the swapped rows.
            const s = document.getElementById('searchInput');
            if (s && s.value) filterRows();
            dpStamp();
        } catch (e) {
            console.warn('dispatch refresh failed', e);
        } finally {
            dpBusy = false;
            if (btn) btn.classList.remove('spinning');
        }
    }

    setInterval(() => {
        if (document.hidden) return;
        if (dpAnyModalOpen()) return;
        const s = document.getElementById('searchInput');
        if (s && s.value) return;
        dpRefresh(false);
    }, 30000);

    dpStamp();
</script>

<style>
    .dp-card-click { cursor:pointer; transition:box-shadow .15s, transform .15s; }
    .dp-card-click:hover { box-shadow:0 6px 20px rgba(231,76,60,.22); transform:translateY(-2px); }
    .dp-trip-row.dp-row-flag > td { background:#FEECEC !important; }
    .dp-trip-row.dp-row-flag { outline:2px solid #E74C3C; outline-offset:-2px; }

    .dp-title-row { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
    .dp-date-badge { display:inline-flex; align-items:center; gap:8px; padding:8px 16px; border-radius:30px; background:#EAF7F5; color:#2e7d72; font-size:.86rem; font-weight:700; border:1px solid #CDE9E4; }
    .dp-date-badge i { font-size:1rem; }
    .dp-cycle-main { font-weight:800; }
    .dp-cycle-range { font-weight:600; font-size:.74rem; color:#3d9490; padding-left:8px; margin-left:4px; border-left:1px solid #BFE2DC; }
    .dp-overnight-tag { display:inline-block; margin-top:3px; padding:1px 7px; border-radius:10px; background:#EEF2FF; color:#4F6BED; font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.03em; }
    .dp-date-nav { display:inline-flex; align-items:center; gap:8px; }
    .dp-date-arrow { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; background:#EAF7F5; color:#2e7d72; border:1px solid #CDE9E4; text-decoration:none; font-size:1.1rem; transition:background .15s,transform .15s; }
    .dp-date-arrow:hover { background:#2e7d72; color:#fff; transform:translateY(-1px); }
    .dp-date-today { display:inline-flex; align-items:center; padding:7px 14px; border-radius:30px; background:#fff; color:#2e7d72; border:1px solid #CDE9E4; font-size:.82rem; font-weight:700; text-decoration:none; }
    .dp-date-today:hover { background:#2e7d72; color:#fff; }

    .dp-btn-refresh { display:inline-flex; align-items:center; gap:6px; padding:9px 16px; border-radius:8px; background:#fff; color:#2e7d72; border:1px solid #CDE9E4; font-weight:700; font-size:.86rem; cursor:pointer; }
    .dp-btn-refresh:hover { background:#EAF7F5; }
    .dp-btn-refresh.spinning i { animation:dpSpin .7s linear infinite; }
    @@keyframes dpSpin { to { transform:rotate(360deg); } }
    .dp-updated { font-size:.78rem; color:#8a98a3; }

    .dp-msg-overlay { position:fixed; inset:0; background:rgba(13,28,40,.5); z-index:3000; display:flex; align-items:center; justify-content:center; padding:24px; }
    .dp-msg-box { background:#fff; border-radius:16px; width:100%; max-width:440px; padding:24px; box-shadow:0 14px 44px rgba(0,0,0,.28); font-family:'Segoe UI',sans-serif; }
    .dp-msg-head { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
    .dp-msg-ico { font-size:1.4rem; color:#E74C3C; }
    .dp-msg-head h3 { margin:0; font-size:1.1rem; color:#1a2a4a; font-weight:800; }
    .dp-msg-list { margin:0 0 18px; padding-left:18px; display:flex; flex-direction:column; gap:7px; }
    .dp-msg-list li { font-size:.85rem; color:#41505e; line-height:1.4; }
    .dp-msg-btn { width:100%; border:none; border-radius:10px; padding:11px; font-size:.9rem; font-weight:800; color:#fff; background:#4AADA8; cursor:pointer; }
    .dp-msg-btn:hover { background:#3d9490; }
</style>

<style>
    :root {
        --rp-text: #2D3748;
        --rp-muted: #9AA5B4;
        --rp-border: #E8ECF0;
        --rp-bg: #F8F9FA;
        --rp-white: #FFFFFF;
        --rp-teal: #4AADA8;
        --rp-radius: 14px;
        --rp-shadow: 0 1px 4px rgba(0,0,0,.06);
    }

    /* ── Page title ─────────────────────────────────────────── */
    .rp-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--rp-text);
        font-family: 'Segoe UI', sans-serif;
        margin-bottom: 20px;
    }

    /* ── Topbar filters ─────────────────────────────────────── */
    .rp-route-wrap, .rp-status-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .rp-filter-label {
        font-size: 0.88rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--rp-text);
        font-weight: 500;
        white-space: nowrap;
    }

    .rp-select-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .rp-select {
        appearance: none;
        padding: 6px 32px 6px 12px;
        border: 1.5px solid var(--rp-border);
        border-radius: 10px;
        font-size: 0.82rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--rp-text);
        background: var(--rp-bg);
        cursor: pointer;
        outline: none;
        font-weight: 500;
    }

    .rp-select-arrow {
        position: absolute;
        right: 10px;
        pointer-events: none;
        color: var(--rp-text);
        display: flex;
    }

    /* ── Stat grid ──────────────────────────────────────────── */
    .dp-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 20px;
        align-items: stretch;
    }

    .rp-stat-card {
        background: var(--rp-white);
        border: 1px solid var(--rp-border);
        border-radius: var(--rp-radius);
        padding: 20px 22px;
        box-shadow: var(--rp-shadow);
    }

    .rp-stat-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .rp-stat-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 16px;
    }

    .rp-stat-icon--green {
        background: #E8F8EE;
        color: #27AE60;
    }

    .rp-stat-icon--red {
        background: #FEECEC;
        color: #E74C3C;
    }

    .rp-stat-icon--amber {
        background: #FFF8E1;
        color: #F59E0B;
    }

    .rp-stat-label {
        font-size: 0.82rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--rp-muted);
        font-weight: 500;
    }

    .rp-stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        color: var(--rp-text);
        font-family: 'Segoe UI', sans-serif;
        line-height: 1.1;
        text-align: center;
    }

    .rp-stat-sub {
        font-size: 0.78rem;
        color: var(--rp-muted);
        font-family: 'Segoe UI', sans-serif;
        margin-top: 4px;
        text-align: center;
    }

    /* ── Side info card (flagged/unavailable) ──────────────── */
    .dp-side-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .dp-side-row {
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        gap: 16px;
        text-align: center;
    }

    .dp-side-row > * {
        flex: 1;
    }

    .dp-side-value--red {
