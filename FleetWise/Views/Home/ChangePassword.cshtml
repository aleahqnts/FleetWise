@model FleetWise.Models.ChangePasswordViewModel
@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="bg-wrapper">
    <div class="card">

        <!-- Left Panel -->
        <div class="left-panel">
            <div class="left-content">
                <img src="~/images/fleetwise-logo.png" alt="FleetWise Logo" class="logo" />
                <div class="brand-name">
                    <span class="brand-fleet">Route</span><span class="brand-wise">Sync</span>
                </div>
                <p class="brand-sub">Operator Dashboard</p>
                <p class="tagline">Drive Your Fleet with Intelligence</p>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <h1 class="sign-in-title">Set Your Password</h1>
            <p class="brand-sub" style="margin-bottom:18px;">You're using a temporary password. Choose your own to continue.</p>

            <form asp-action="ChangePassword" asp-controller="Home" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-message">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="NewPassword" type="password" class="input-field" placeholder="New password" autocomplete="new-password" />
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </span>
                    <input asp-for="ConfirmPassword" type="password" class="input-field" placeholder="Confirm new password" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>

                <button type="submit" class="sign-in-btn">Save Password</button>
            </form>
        </div>

    </div>
</div>
