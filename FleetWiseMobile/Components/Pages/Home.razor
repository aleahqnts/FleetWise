@page "/home"
@implements IDisposable
@inject SessionService Session
@inject DriverDataService Data
@inject TelemetryQueue Queue
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (loading)
{
    <div class="loading">Loading...</div>
}
else
{
    <div class="home">
        <div class="header">
            <div>
                <p class="greet">@Greeting,</p>
                <h1 class="name">@Session.DisplayName</h1>
            </div>
            <img class="avatar" src="images/user-avatar.png" alt="" />
        </div>

        @if (!string.IsNullOrEmpty(statusMsg))
        {
            <p class="status-msg">@statusMsg</p>
        }

        @if (!IsAvailable)
        {
            <div class="status-card">
                <span class="status-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#d0494b" stroke-width="2"><circle cx="12" cy="12" r="9" /><path d="M9 9l6 6M15 9l-6 6" /></svg>
                </span>
                <div>
                    <p class="s-title red">You are unavailable</p>
                    <p class="s-sub">You are unable to receive assignments</p>
                </div>
            </div>

            <div class="prompt-card green-bg">
                <div>
                    <p class="s-title">Need to be available?</p>
                    <p class="s-sub">You can set yourself as available</p>
                </div>
                <button class="toggle off" @onclick="ToggleAvailability" disabled="@toggling"><span></span></button>
            </div>

            @if (lastTrip is not null)
            {
                <div class="info-card row">
                    <div>
                        <p class="s-title">Last Trip</p>
                        <p class="s-sub">@lastTrip.Date.ToString("MMMM d, yyyy")</p>
                    </div>
                    <button class="link-btn" @onclick="@(() => Nav.NavigateTo("/trips"))">View Trips</button>
                </div>
            }
        }
        else
        {
            <div class="status-card">
                <span class="status-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#2fae74" stroke-width="2"><circle cx="12" cy="12" r="9" /><path d="M8 12.5l2.5 2.5 5-6" /></svg>
                </span>
                <div>
                    <p class="s-title green">You are available</p>
                    <p class="s-sub">You can receive assignments</p>
                </div>
            </div>

            @if (assignment is not null)
            {
                <h2 class="section">@(PhTime.Now >= ShiftStart ? "Current Assignment" : "Upcoming Assignment")</h2>
                <div class="assign-card">
                    <div class="line">
                        <span class="i cal"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2" /><path d="M3 9h18M8 3v4M16 3v4" /></svg></span>
                        @DateLabel
                    </div>
                    <div class="line">
                        <span class="i sun"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19" /></svg></span>
                        @assignment.ShiftType Shift
                    </div>
                    <div class="line">
                        <span class="i clock"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg></span>
                        @TimeRange
                    </div>
                    <div class="line">
                        <span class="i pin"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11z" /><circle cx="12" cy="10" r="2.5" /></svg></span>
                        @(route?.RouteName ?? $"Route {assignment.RouteId}")
                    </div>

                    <div class="divider"></div>
                    <p class="s-sub">Bus to Drive</p>
                    <div class="bus-row">
                        <span class="bus-ico"><svg viewBox="0 0 49 52" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.25 45.4997C11.6715 45.4997 11.1866 45.292 10.7953 44.8768C10.404 44.4615 10.2083 43.9469 10.2083 43.333V38.8913C9.59579 38.1691 9.10239 37.3656 8.72808 36.4809C8.35378 35.5962 8.16663 34.6302 8.16663 33.583V12.9997C8.16663 10.0025 9.4767 7.8087 12.0968 6.41842C14.717 5.02815 18.8513 4.33301 24.5 4.33301C30.3527 4.33301 34.5382 5.00106 37.0562 6.33717C39.5743 7.67329 40.8333 9.89412 40.8333 12.9997V33.583C40.8333 34.6302 40.6461 35.5962 40.2718 36.4809C39.8975 37.3656 39.4041 38.1691 38.7916 38.8913V43.333C38.7916 43.9469 38.596 44.4615 38.2046 44.8768C37.8133 45.292 37.3284 45.4997 36.75 45.4997H34.7083C34.1298 45.4997 33.6449 45.292 33.2536 44.8768C32.8623 44.4615 32.6666 43.9469 32.6666 43.333V41.1663H16.3333V43.333C16.3333 43.9469 16.1376 44.4615 15.7463 44.8768C15.355 45.292 14.8701 45.4997 14.2916 45.4997H12.25ZM12.25 21.6663H36.75V15.1663H12.25V21.6663ZM17.3541 34.6663C18.2048 34.6663 18.9279 34.3504 19.5234 33.7184C20.1189 33.0865 20.4166 32.3191 20.4166 31.4163C20.4166 30.5136 20.1189 29.7462 19.5234 29.1143C18.9279 28.4823 18.2048 28.1663 17.3541 28.1663C16.5034 28.1663 15.7803 28.4823 15.1849 29.1143C14.5894 29.7462 14.2916 30.5136 14.2916 31.4163C14.2916 32.3191 14.5894 33.0865 15.1849 33.7184C15.7803 34.3504 16.5034 34.6663 17.3541 34.6663ZM31.6458 34.6663C32.4965 34.6663 33.2196 34.3504 33.8151 33.7184C34.4106 33.0865 34.7083 32.3191 34.7083 31.4163C34.7083 30.5136 34.4106 29.7462 33.8151 29.1143C33.2196 28.4823 32.4965 28.1663 31.6458 28.1663C30.7951 28.1663 30.072 28.4823 29.4765 29.1143C28.881 29.7462 28.5833 30.5136 28.5833 31.4163C28.5833 32.3191 28.881 33.0865 29.4765 33.7184C30.072 34.3504 30.7951 34.6663 31.6458 34.6663ZM13.1687 10.833H36.0354C35.525 10.2191 34.4276 9.70454 32.7432 9.28926C31.0588 8.87398 28.3451 8.66634 24.602 8.66634C20.9611 8.66634 18.2984 8.89204 16.614 9.34342C14.9296 9.79481 13.7812 10.2913 13.1687 10.833ZM16.3333 36.833H32.6666C33.7895 36.833 34.7508 36.4087 35.5505 35.5601C36.3501 34.7115 36.75 33.6913 36.75 32.4997V25.9997H12.25V32.4997C12.25 33.6913 12.6498 34.7115 13.4494 35.5601C14.2491 36.4087 15.2104 36.833 16.3333 36.833Z" fill="#4BA2A3" /></svg></span>
                        <div>
                            <p class="bus">@(vehicle?.VehicleId ?? assignment.VehicleId)</p>
                            <p class="s-sub">Plate Number: @(vehicle?.PlateNumber ?? "—")</p>
                        </div>
                    </div>

                    @if (!CanStart)
                    {
                        <div class="upcoming-note">@LockLabel</div>
                    }
                    else if (checklist is not null)
                    {
                        <div class="checklist-done">
                            <div>
                                <p class="green s-title">Bus Checklist Completed</p>
                                <p class="s-sub">@checklist.SubmittedAt.ToString("MMM d, h:mm tt")</p>
                            </div>
                            <button class="link-btn" @onclick="@(() => Nav.NavigateTo($"/checklist-log/{assignment.TripId}"))">View Log</button>
                        </div>
                        @if (assignment.TripStatus == "Active")
                        {
                            <button class="btn-green" @onclick="@(() => Nav.NavigateTo($"/trip-active/{assignment.TripId}"))">Resume Trip</button>
                        }
                        else
                        {
                            <button class="btn-green" @onclick="StartTrip">Start Trip</button>
                        }
                    }
                    else
                    {
                        <button class="btn-teal" @onclick="StartChecklist">Start Bus Checklist</button>
                    }
                </div>

                @if (!CanStart || checklist is null)
                {
                    <div class="prompt-card">
                        <div>
                            <p class="s-title">Need to be unavailable?</p>
                            <p class="s-sub">You can set yourself as unavailable</p>
                        </div>
                        <button class="toggle on" @onclick="ToggleAvailability" disabled="@toggling"><span></span></button>
                    </div>
                }
            }
            else
            {
                @if (lastTrip is not null)
                {
                    <div class="info-card row">
                        <div>
                            <p class="s-title">Today's Summary</p>
                            <p class="s-sub">@DateTime.Today.ToString("MMMM d, yyyy")</p>
                        </div>
                        <button class="link-btn" @onclick="@(() => Nav.NavigateTo("/trips"))">View Trips</button>
                    </div>
                }
                <div class="info-card">
                    <p class="s-title">No upcoming assignment</p>
                    <p class="s-sub">Enjoy your rest. You will be notified for your next assignment.</p>
                </div>

                <div class="prompt-card">
                    <div>
                        <p class="s-title">Need to be unavailable?</p>
                        <p class="s-sub">You can set yourself as unavailable</p>
                    </div>
                    <button class="toggle on" @onclick="ToggleAvailability" disabled="@toggling"><span></span></button>
                </div>
            }
        }
    </div>

    @if (showUnavailModal)
    {
        <div class="overlay">
            <div class="ua-modal">
                <h2>Go unavailable?</h2>
                <p class="ua-sub">You have an assigned shift. This flags it for your dispatcher.</p>

                <p class="ua-label">Reason</p>
                <div class="chips">
                    @foreach (var r in reasons)
                    {
                        <button class="chip @(reasonChoice == r ? "on" : "")" @onclick="@(() => reasonChoice = r)">@r</button>
                    }
                </div>
                <input class="ua-note" placeholder="Add a note (optional)" @bind="reasonNote" @bind:event="oninput" />

                <div class="ua-actions">
                    <button class="btn-cancel" @onclick="@(() => showUnavailModal = false)" disabled="@toggling">Cancel</button>
                    <button class="btn-confirm" @onclick="ConfirmUnavailable" disabled="@(toggling || !ReasonReady)">Confirm</button>
                </div>
            </div>
        </div>
    }

    @if (toggling)
    {
        <div class="busy-overlay"><span class="spinner"></span></div>
    }
}

@code {
    private bool loading = true;
    private bool toggling;
    private string? statusMsg;
    private string availability = "Unavailable";
    private bool isUpcoming;
    private Trip? assignment;
    private BusRoute? route;
    private Vehicle? vehicle;
    private BusChecklist? checklist;
    private Trip? lastTrip;

    private bool showUnavailModal;
    private string? reasonChoice;
    private string reasonNote = "";
    private readonly string[] reasons = { "Emergency", "Sick", "Vehicle problem", "Personal", "Other" };
    private bool ReasonReady => reasonChoice is not null || !string.IsNullOrWhiteSpace(reasonNote);

    private bool IsAvailable => availability == "Available";

    private string Greeting
    {
        get
        {
            var h = DateTime.Now.Hour;
            return h < 12 ? "Good Morning" : h < 18 ? "Good Afternoon" : "Good Evening";
        }
    }

    private string DateLabel
    {
        get
        {
            if (assignment is null) return "";
            var d = assignment.Date.Date;
            var prefix = d == DateTime.Today ? "Today, " : "";
            return prefix + d.ToString("MMMM d, yyyy");
        }
    }

    private const int LeadHours = 2; // checklist/start opens this many hours before shift

    private DateTime ShiftStart => assignment is null
        ? DateTime.MinValue
        : assignment.Date.Date + assignment.ShiftStartTime;

    // Unlock window: from LeadHours before shift start onward.
    private bool CanStart => assignment is not null && PhTime.Now >= ShiftStart - TimeSpan.FromHours(LeadHours);

    private string LockLabel
    {
        get
        {
            if (assignment is null) return "";
            var unlock = ShiftStart - TimeSpan.FromHours(LeadHours);
            if (unlock.Date == DateTime.Today) return $"Checklist opens at {unlock:h:mm tt}";
            if (unlock.Date == DateTime.Today.AddDays(1)) return $"Checklist opens tomorrow, {unlock:h:mm tt}";
            return $"Checklist opens {unlock:MMM d, h:mm tt}";
        }
    }

    private string TimeRange => assignment is null ? "" :
        $"{DateTime.Today.Add(assignment.ShiftStartTime):h:mm tt} to {DateTime.Today.Add(assignment.ShiftEndTime):h:mm tt}";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/"); return; }
        // Await: push any queued trip finalize FIRST so Load() reads the trip as
        // Completed (not a stale "Active" -> phantom "Resume Trip").
        try { await Queue.FlushAsync(); } catch { /* offline: stays queued */ }
        await Load();
    }

    private async Task Load()
    {
        loading = true;
        try
        {
            var uid = Session.CurrentUser!.UserId;

            availability = await Data.GetAvailabilityAsync(uid);

            assignment = await Data.GetTodayAssignmentAsync(uid);
            isUpcoming = false;
            if (assignment is null)
            {
                assignment = await Data.GetUpcomingAssignmentAsync(uid);
                isUpcoming = assignment is not null;
            }

            if (assignment is not null)
            {
                route = await Data.GetRouteAsync(assignment.RouteId);
                vehicle = await Data.GetVehicleAsync(assignment.VehicleId);
                checklist = isUpcoming ? null : await Data.GetChecklistAsync(assignment.TripId);
            }
            else
            {
                route = null; vehicle = null; checklist = null;
            }

            lastTrip = await Data.GetLastCompletedTripAsync(uid);
        }
        catch (Exception ex)
        {
            statusMsg = "Couldn't load. Check your connection.";
            System.Diagnostics.Debug.WriteLine($"[Home.Load] {ex}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ToggleAvailability()
    {
        if (toggling) return;

        if (IsAvailable)
        {
            // Going Unavailable while holding a shift -> warn + capture reason.
            if (assignment is not null)
            {
                reasonChoice = null;
                reasonNote = "";
                showUnavailModal = true;
                return;
            }
            await ApplyAvailability("Unavailable", null);
        }
        else
        {
            await ApplyAvailability("Available", null);
        }
    }

    private async Task ConfirmUnavailable()
    {
        var reason = !string.IsNullOrWhiteSpace(reasonNote) ? reasonNote.Trim() : reasonChoice;
        showUnavailModal = false;
        await ApplyAvailability("Unavailable", reason);
    }

    private async Task ApplyAvailability(string status, string? reason)
    {
        toggling = true;
        statusMsg = null;
        try
        {
            await Data.SetAvailabilityAsync(Session.CurrentUser!.UserId, status, reason);
            await Load();
        }
        catch (Exception ex)
        {
            statusMsg = "Couldn't update availability. Check your connection.";
            System.Diagnostics.Debug.WriteLine($"[Home.Toggle] {ex}");
        }
        finally
        {
            toggling = false;
        }
    }

    private void StartChecklist() => Nav.NavigateTo($"/checklist/{assignment!.TripId}");
    private void StartTrip() => Nav.NavigateTo($"/trip-details/{assignment!.TripId}");

    private DotNetObjectReference<Home>? _ptrRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ptrRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("ptr.set", _ptrRef);
        }
    }
    [JSInvokable] public async Task Refresh() { await Load(); StateHasChanged(); }
    public void Dispose() => _ptrRef?.Dispose();
}
