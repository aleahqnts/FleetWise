@page "/trip-active/{TripId}"
@layout LoginLayout
@implements IDisposable
@inject SessionService Session
@inject DriverDataService Data
@inject ITripTracker Tracker
@inject TelemetryQueue Queue
@inject NavigationManager Nav
@using System.Text.Json

@if (loading)
{
    <div class="ta-loading">Loading...</div>
}
else if (trip is null)
{
    <div class="ta"><p class="ta-empty">Trip not found.</p></div>
}
else
{
    <div class="ta">
        <div class="ta-head">
            <h1>Active Trip</h1>
            <p class="status"><span class="dot"></span> In Progress</p>
        </div>
        <p class="date">@DateTime.Today.ToString("dddd, MMMM d, yyyy")</p>

        <div class="bus-card">
