@page "/trips"
@inject SessionService Session
@inject DriverDataService Data
@inject NavigationManager Nav

@if (loading)
{
    <div class="page-loading">Loading...</div>
}
else
{
    <div class="trips">
        <h1 class="trips-title">Trips</h1>

        @if (!trips.Any())
        {
            <p class="muted">No trips yet.</p>
        }
        else
        {
            @foreach (var g in Grouped)
            {
                <h2 class="group">@g.Key</h2>
                @foreach (var t in g)
                {
                    <div class="trip-card">
                        <div>
                            <p class="tid">@t.TripId</p>
                            <p class="tdate">@t.Date.ToString("MMMM d, yyyy")</p>
                        </div>
                        <button class="link-btn" @onclick="@(() => Nav.NavigateTo($"/trip-report/{t.TripId}"))">View Trip</button>
                    </div>
                }
            }
        }
    </div>
}

@code {
    private bool loading = true;
    private List<Trip> trips = new();

    private IEnumerable<IGrouping<string, Trip>> Grouped => trips.GroupBy(t => Label(t.Date));

    private static string Label(DateTime d)
    {
        var dd = d.Date;
        if (dd == DateTime.Today) return "Today";
        if (dd == DateTime.Today.AddDays(-1)) return "Yesterday";
        return dd.ToString("MMMM d, yyyy");
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn) { Nav.NavigateTo("/"); return; }
        trips = await Data.GetTripsForDriverAsync(Session.CurrentUser!.UserId);
        loading = false;
    }
}
