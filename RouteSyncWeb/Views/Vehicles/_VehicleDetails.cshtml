@model VehicleDetailsViewModel
@*
    View Vehicle Details — fetched into #viewVehicleContent per vehicle.
    Renders the modal header + body; the shell lives in _ViewVehicleModal.cshtml.
*@
@functions {
    string InspectionClass(string badge) => badge switch
    {
        "Flagged" => "vh-badge--flagged",
        "Passed" => "vh-badge--ok",
        "Resolved" => "vh-badge--ok",
        "Pending" => "vh-badge--pending",
        _ => "vh-badge--default"
    };

    string MaintClass(string status) => status switch
    {
        "No Issues" => "vh-badge--ok",
        "Needs Attention" => "vh-badge--attention",
        "Under Repair" => "vh-badge--repair",
        _ => "vh-badge--default"
    };
}

<div class="modal-header">
    <h5 class="modal-title vh-modal-title">@Model.VehicleId</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body vh-modal-body">

    <!-- Vehicle Profile -->
    <div class="vh-section-header">Vehicle Profile</div>
    <div class="vh-section-body">
        <div class="vh-detail-row"><strong>Plate Number:</strong> @Model.PlateNumber</div>
        <div class="vh-detail-row"><strong>Route:</strong> @Model.RouteName</div>
    </div>

    <!-- Passenger Counter Camera (Phase 8e: remote calibration, any bus, no trip needed) -->
    <div class="vh-section-header">Passenger Counter</div>
    <div class="vh-section-body">
        @if (!string.IsNullOrEmpty(Model.CounterDeviceId))
        {
            <div class="vh-detail-row"><strong>Counter Phone:</strong> @Model.CounterDeviceId</div>
            <div class="vh-review-actions" style="margin-top:8px;">
                <button type="button" class="vh-btn vh-btn--primary" onclick="camOpen('@Model.VehicleId')">Calibrate Camera</button>
            </div>
        }
        else
        {
            <div class="vh-detail-row vh-detail-empty">No counter phone is bound to this bus.</div>
        }
    </div>

    <!-- Inspection Log -->
    <div class="vh-section-header">
        <span>Inspection Log</span>
        @if (Model.HasInspection)
        {
            <span class="vh-section-badge @InspectionClass(Model.InspectionBadge)">@Model.InspectionBadge</span>
        }
    </div>
    <div class="vh-section-body">
        @if (Model.HasInspection)
        {
            <div class="vh-detail-row"><strong>Reported By:</strong> @Model.ReportedBy</div>
            <div class="vh-detail-row"><strong>Time of Report:</strong> @Model.TimeOfReport</div>
            <div class="vh-detail-row"><strong>Issue:</strong> @Model.Issue</div>
            @if (Model.InspectionSections.Count > 0)
            {
                <details class="vh-flag-details">
                    <summary>Flagged items (@Model.InspectionSections.Sum(s => s.Items.Count))</summary>
                    @foreach (var grp in Model.InspectionSections)
                    {
                        <div class="vh-flag-group">
                            <div class="vh-flag-group-label">@grp.Section</div>
                            <ul class="vh-flag-list">
                                @foreach (var item in grp.Items)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>
                    }
                </details>
            }
        }
        else
        {
            <div class="vh-detail-row vh-detail-empty">No inspection logged for this vehicle.</div>
        }
    </div>

    <!-- Maintenance Log -->
    <div class="vh-section-header">
        <span>Maintenance Log</span>
        <span class="vh-maint-head-right">
            <button type="button" class="vh-btn-mini" onclick="vhScheduleMaintenance('@Model.VehicleId')">+ Schedule Maintenance</button>
            <span class="vh-section-badge @MaintClass(Model.CurrentStatus)">@Model.CurrentStatus</span>
        </span>
    </div>
    <div class="vh-section-body">
        <div class="vh-detail-row"><strong>Current Status:</strong> @Model.CurrentStatus</div>
        @if (Model.HasMaintenance)
        {
            <ul class="vh-timeline">
                @foreach (var entry in Model.MaintenanceEntries)
                {
                    <li>
                        <div class="vh-tl-top">
                            <span class="vh-tl-summary">@entry.Summary</span>
                            <span class="vh-tl-status @(entry.IsResolved ? "vh-tl--resolved" : "vh-tl--open")">@entry.Status</span>
                        </div>
                        <span class="vh-tl-date">@entry.Date</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="vh-detail-row vh-detail-empty">No maintenance history.</div>
        }
    </div>

    <!-- Flag Review / Actions -->
    @if (Model.OpenLogId.HasValue || Model.OutOfService || Model.IncidentThreads.Count > 0)
    {
        <div class="vh-section-header">
            <span>Flag Review</span>
            @if (Model.OutOfService)
            {
                <span class="vh-section-badge vh-badge--oos">Out of Service</span>
            }
            else if (Model.OpenLogId.HasValue)
            {
                <span class="vh-section-badge vh-badge--flagged">Flagged</span>
            }
        </div>
        <div class="vh-section-body">
            @if (Model.OutOfService)
            {
                <div class="vh-oos-banner">This bus is <strong>Out of Service</strong>. Dispatch cannot assign it.</div>
            }

            <div class="vh-review-actions">
                @if (Model.OpenLogId.HasValue)
                {
                    <button type="button" class="vh-btn vh-btn--resolve" onclick="vhResolve(@Model.OpenLogId)">Resolve &amp; Return to Ready</button>
                }
                @if (Model.OutOfService)
                {
                    <button type="button" class="vh-btn vh-btn--outline" onclick="vhSetService('@Model.VehicleId', false, @(Model.OpenLogId?.ToString() ?? "null"))">Return to Service</button>
                }
                else
                {
                    <button type="button" class="vh-btn vh-btn--danger" onclick="vhMarkOutOfService('@Model.VehicleId', @(Model.OpenLogId?.ToString() ?? "null"))">Mark Out of Service</button>
                }
            </div>

            @if (Model.OpenLogId.HasValue)
            {
                <div class="vh-note-form">
                    <textarea id="vhNoteInput" class="vh-form-input" rows="2" placeholder="Add a comment or note about this issue…"></textarea>
                    <button type="button" class="vh-btn vh-btn--primary" onclick="vhAddNote(@Model.OpenLogId)">Add Note</button>
                </div>
            }

            @if (Model.IncidentThreads.Count > 0)
            {
                <div class="vh-thread-label">History</div>
                @foreach (var thread in Model.IncidentThreads)
                {
                    <div class="vh-thread-group">
                        <ul class="vh-thread">
                            @foreach (var n in thread.Notes)
                            {
                                <li>
                                    <span class="vh-thread-action">@n.Action</span>
                                    @if (!string.IsNullOrWhiteSpace(n.Note))
                                    {
                                        <span class="vh-thread-note">@n.Note</span>
                                    }
                                    <span class="vh-thread-meta">@n.AuthorName · @n.When</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else
            {
                <div class="vh-detail-row vh-detail-empty">No actions or comments yet.</div>
            }
        </div>
    }

</div>
