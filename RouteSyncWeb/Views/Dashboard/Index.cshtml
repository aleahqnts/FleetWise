@model FleetWise.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- PAGE TITLE + REFRESH -->
<div class="db-title-row">
    <h2 class="db-title">Dashboard</h2>
    <div class="db-title-tools">
        <span class="db-date-badge">@Model.Today.ToString("ddd, dd MMM yyyy")</span>
        <button class="db-btn-refresh" id="dbRefreshBtn" onclick="dbRefresh(true)" title="Refresh this page only">
            <span class="db-refresh-ico">&#x21bb;</span> Refresh
        </button>
        <span class="db-updated" id="dbUpdated" title="Auto-refreshes every 30 seconds"></span>
    </div>
</div>

<!-- LIVE REGION (swapped by AJAX refresh) -->
<div id="dbStats">

<!-- chart data carried here so refresh can update the chart without reloading the page -->
<script type="application/json" id="dbChartData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData))</script>

<!-- STAT CARDS -->
<div class="db-stat-grid">

    <div class="db-stat-card">
        <div class="db-stat-header">
            <span class="db-stat-icon db-stat-icon--green">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <rect x="1" y="3" width="15" height="13" rx="2" />
                    <path d="M16 8h4l3 3v5h-7V8z" />
                    <circle cx="5.5" cy="18.5" r="2.5" />
                    <circle cx="18.5" cy="18.5" r="2.5" />
                </svg>
            </span>
            <span class="db-stat-label">Active Trips</span>
        </div>
        <div class="db-stat-value">@Model.ActiveTrips</div>
    </div>

    <a href="/Vehicles?status=Flagged" class="db-stat-card db-stat-card--click" style="text-decoration:none;color:inherit;" title="View flagged vehicles">
        <div class="db-stat-header">
            <span class="db-stat-icon db-stat-icon--red">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="8" y1="12" x2="16" y2="12" />
                </svg>
            </span>
            <span class="db-stat-label">Flagged Vehicles</span>
        </div>
        <div class="db-stat-value">@Model.FlaggedVehicles</div>
    </a>

    <div class="db-stat-card db-stat-card--click" onclick="dbToggleBreakdown()" title="Click for per-trip breakdown">
        <div class="db-stat-header">
            <span class="db-stat-icon db-stat-icon--blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
            </span>
            <span class="db-stat-label">Total Boarded</span>
            <span class="db-stat-chevron" id="dbPaxChevron">&#9656;</span>
        </div>
        <div class="db-stat-value">@Model.TotalPassengers</div>
        @if (Model.PassengerDelta != 0)
        {
            var deltaClass = Model.PassengerDelta >= 0 ? "db-stat-delta--up" : "db-stat-delta--down";
            var deltaArrow = Model.PassengerDelta >= 0 ? "&#x2B06;" : "&#x2B07;";
            var deltaSign = Model.PassengerDelta >= 0 ? "+" : "";
            <div class="db-stat-delta @deltaClass">@Html.Raw(deltaArrow) @deltaSign@Model.PassengerDelta vs yesterday</div>
        }
    </div>

    <div class="db-stat-card">
        <div class="db-stat-header">
            <span class="db-stat-icon db-stat-icon--pink">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <line x1="12" y1="1" x2="12" y2="23" />
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
            </span>
            <span class="db-stat-label">Total Revenue</span>
        </div>
        <div class="db-stat-value">&#8369;@Model.TotalRevenue.ToString("N0")</div>
        @if (Model.RevenueDelta != 0)
        {
            var deltaClass = Model.RevenueDelta >= 0 ? "db-stat-delta--up" : "db-stat-delta--down";
            var deltaArrow = Model.RevenueDelta >= 0 ? "&#x2B06;" : "&#x2B07;";
            var deltaSign = Model.RevenueDelta >= 0 ? "+" : "";
            <div class="db-stat-delta @deltaClass">@Html.Raw(deltaArrow) &#8369;@deltaSign@Model.RevenueDelta.ToString("N0") vs yesterday</div>
        }
    </div>

</div>

<!-- TOTAL PASSENGERS MODAL (opened by the card) -->
<div class="db-modal-overlay" id="dbBreakdown" style="display:none;" onclick="if(event.target===this)dbCloseModal()">
    <div class="db-modal">
        @{
            // Only trips that actually boarded — not-yet-started (0) rows add no signal.
            var boardedRows = Model.ActiveTripBreakdown.Where(r => r.Passengers > 0).ToList();
        }
        <div class="db-modal-head">
            <div>
                <div class="db-modal-title">Total Boarded Breakdown</div>
                <div class="db-modal-sub">Trips with boarding (@boardedRows.Count) &bull; @Model.TotalPassengers boarded</div>
            </div>
            <button class="db-modal-close" onclick="dbCloseModal()" aria-label="Close">&times;</button>
        </div>
        <div class="db-modal-body">
            @if (boardedRows.Count == 0)
            {
                <div class="db-breakdown-empty">No boarded trips this service day yet.</div>
            }
            else
            {
                <table class="db-breakdown-table">
                    <thead>
                        <tr><th>Trip</th><th>Route</th><th>Vehicle</th><th>Shift</th><th>Status</th><th class="db-num">Boarded</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var row in boardedRows)
                        {
                            <tr>
                                <td>@row.TripId</td>
                                <td>@row.RouteName</td>
                                <td>@row.VehicleId</td>
                                <td>@row.ShiftType</td>
                                <td>@row.Status</td>
                                <td class="db-num"><strong>@row.Passengers</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

</div><!-- /#dbStats -->

<!-- MIDDLE ROW: Chart + Map -->
<div class="db-mid-grid">

    <!-- Passenger Demand Chart -->
    <div class="db-card db-card--chart">
        <div class="db-card-header">
            <span class="db-card-icon db-card-icon--teal">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <line x1="18" y1="20" x2="18" y2="10" />
                    <line x1="12" y1="20" x2="12" y2="4" />
                    <line x1="6" y1="20" x2="6" y2="14" />
                </svg>
            </span>
            <span class="db-card-title">Passengers Boarded by Hour</span>
            <span class="db-badge db-badge--teal">@Model.SelectedRouteName</span>
            <div class="db-chart-legend">
                <span class="db-legend-swatch" style="background:#4AADA8;"></span>
                <span class="db-legend-text">@Model.SelectedRouteName</span>
            </div>
        </div>
        <canvas id="demandChart" class="db-chart-canvas"></canvas>
    </div>

    <!-- Fleet Map -->
    <div class="db-card db-card--map">
        <div class="db-card-header">
            <span class="db-card-icon db-card-icon--green">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                     stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21" />
                    <line x1="9" y1="3" x2="9" y2="18" />
                    <line x1="15" y1="6" x2="15" y2="21" />
                </svg>
            </span>
            <span class="db-card-title">Fleet Map</span>
        </div>
        <a class="db-map-link" href="@Url.Action("Index", "FleetMap")" aria-label="Open Fleet Map">
            <div id="dashFleetMap" class="db-map-leaflet"></div>
            <div class="db-map-legend">
                <div class="db-map-legend-title">Routes</div>
                <div id="dashMapLegend"></div>
            </div>
            <div class="db-map-overlay"><span class="db-map-more">Show more &rarr;</span></div>
        </a>
    </div>

    </div>


    <!-- Chart.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        // Hour labels from the ViewModel; per-hour onboard counts read from the live
        // region so an AJAX refresh can update the chart without a reload.
        const chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
        const chartDay1 = '@Model.Today.ToString("ddd, dd MMM")';
        const chartDay2 = '@Model.Today.AddDays(1).ToString("ddd, dd MMM")';
        // midnight = first "12:00 AM" -> start of the 2nd calendar day in this 6am->6am cycle
        const dbMidnightIdx = chartLabels.indexOf('12:00 AM');

        function dbReadHourly() {
            try { return JSON.parse(document.getElementById('dbChartData').textContent) || []; }
            catch (e) { return []; }
        }

        // Tints the 2nd day's region + draws a divider and day labels so it's obvious
        // where one calendar day ends and the next begins inside the cycle.
        const dbDayBandPlugin = {
            id: 'dbDayBand',
            beforeDraw(chart) {
                if (dbMidnightIdx < 0) return;
                const { ctx, chartArea: area, scales } = chart;
                const xMid = scales.x.getPixelForValue(dbMidnightIdx);
                ctx.save();
                // shade day 2
                ctx.fillStyle = 'rgba(59,130,246,0.05)';
                ctx.fillRect(xMid, area.top, area.right - xMid, area.bottom - area.top);
                // divider
                ctx.strokeStyle = 'rgba(59,130,246,0.45)';
                ctx.lineWidth = 1.2;
                ctx.setLineDash([5, 4]);
                ctx.beginPath();
                ctx.moveTo(xMid, area.top);
                ctx.lineTo(xMid, area.bottom);
                ctx.stroke();
                ctx.setLineDash([]);
                // day labels
                ctx.font = '600 11px Segoe UI';
                ctx.textBaseline = 'top';
                ctx.fillStyle = '#9AA5B4';
                ctx.textAlign = 'center';
                ctx.fillText(chartDay1, (area.left + xMid) / 2, area.top + 2);
                ctx.fillStyle = '#3B82F6';
                ctx.fillText(chartDay2, (xMid + area.right) / 2, area.top + 2);
                ctx.restore();
            }
        };

        const ctx = document.getElementById('demandChart').getContext('2d');
        window.demandChart = new Chart(ctx, {
        type: 'line',
        plugins: [dbDayBandPlugin],
        data: {
        labels: chartLabels,
        datasets: [{
        label: 'Passengers boarded',
        data: dbReadHourly(),
        borderColor: '#4AADA8',
        backgroundColor: 'rgba(74,173,168,0.08)',
        borderWidth: 2.2,
        pointBackgroundColor: '#4AADA8',
        pointRadius: 5,
        pointHoverRadius: 9,
        pointHitRadius: 25,
        tension: 0.25,
        fill: true
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        // wider grab zone: hover snaps to nearest point even without pixel-perfect aim
        interaction: { mode: 'index', intersect: false, axis: 'x' },
        plugins: {
        legend: { display: false },
        tooltip: {
        callbacks: {
        title: items => 'Hour: ' + items[0].label,
        label: item => 'Boarded so far: ' + item.parsed.y
        }
        }
        },
        scales: {
        x: {
        title: { display: true, text: 'Hour of day (PHT)', color: '#9AA5B4', font: { size: 11, family: 'Segoe UI' } },
        grid: { color: '#F0F0F0' },
        ticks: { font: { size: 11, family: 'Segoe UI' }, color: '#9AA5B4' }
        },
        y: {
        beginAtZero: true,
        suggestedMax: dbYMax(dbReadHourly()),
        title: { display: true, text: 'Passengers', color: '#9AA5B4', font: { size: 11, family: 'Segoe UI' } },
        ticks: { precision: 0, font: { size: 11, family: 'Segoe UI' }, color: '#9AA5B4' },
        grid: { color: '#F0F0F0' }
        }
        }
        }
        });

        // top of axis = peak + ~20% headroom (rounded to a nice 10), so the line never
        // hugs the very top of the chart.
        function dbYMax(data) {
        const m = Math.max(0, ...data.filter(v => v != null));
        return m <= 0 ? 10 : Math.ceil((m * 1.2) / 10) * 10;
        }

        function dbUpdateChart() {
        const d = dbReadHourly();
        window.demandChart.data.datasets[0].data = d;
        window.demandChart.options.scales.y.suggestedMax = dbYMax(d);
        window.demandChart.update();
        }

        // ── Total Passengers modal ────────────────────────────────────
        function dbToggleBreakdown() {
        const m = document.getElementById('dbBreakdown');
        if (m) m.style.display = 'flex';
        }
        function dbCloseModal() {
        const m = document.getElementById('dbBreakdown');
        if (m) m.style.display = 'none';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') dbCloseModal(); });

        // ── AJAX refresh (manual button + silent 30s poll) ────────────
        let dbBusy = false;
        function dbStamp() {
        const el = document.getElementById('dbUpdated');
        if (el) el.textContent = 'Updated ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        async function dbRefresh(manual) {
        if (dbBusy) return;
        dbBusy = true;
        const btn = document.getElementById('dbRefreshBtn');
        if (manual && btn) btn.classList.add('spinning');
        // keep the modal open across refreshes
        const wasOpen = document.getElementById('dbBreakdown')?.style.display === 'flex';
        try {
        const res = await fetch(window.location.href, { headers: { 'X-Requested-With': 'fetch' } });
        const html = await res.text();
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const fresh = doc.getElementById('dbStats');
        const cur = document.getElementById('dbStats');
        if (fresh && cur) cur.innerHTML = fresh.innerHTML;
        if (wasOpen) { const p = document.getElementById('dbBreakdown'); if (p) p.style.display = 'flex'; }
        dbUpdateChart();
        dbStamp();
        } catch (e) {
        console.warn('dashboard refresh failed', e);
        } finally {
        dbBusy = false;
        if (btn) btn.classList.remove('spinning');
        }
        }
        setInterval(() => {
        if (document.hidden) return;
        dbRefresh(false);
        }, 30000);
        dbStamp();

        // ── Filter form helper ────────────────────────────────────────
        // Re-submits the filter form whenever the route dropdown changes.
        document.getElementById('routeSelect').addEventListener('change', function () {
        document.getElementById('filterForm').submit();
        });
    </script>

    <!-- Fleet Map preview (same live data as the Fleet Map page) -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/dashboard-fleetmap.js" asp-append-version="true"></script>

    <style>
        /* ── Variables (inherit from sidebar) ──────────────────── */
        :root {
        --db-teal: #4AADA8;
        --db-teal-light: #E8F6F5;
        --db-text: #2D3748;
        --db-muted: #9AA5B4;
        --db-border: #E8ECF0;
        --db-bg: #F8F9FA;
        --db-white: #FFFFFF;
        --db-radius: 14px;
        --db-shadow: 0 1px 4px rgba(0,0,0,.06);
        }

        /* ── Top bar ────────────────────────────────────────────── */
        .db-topbar {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 28px;
        }

        .db-route-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
        }

        .db-route-label {
        font-size: 0.9rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--db-text);
        font-weight: 500;
        }

        .db-route-select-wrap {
        position: relative;
        display: flex;
        align-items: center;
        }

        .db-route-select {
        width: 200px;
        appearance: none;
        padding: 7px 14px 7px 14px;
        font-size: 0.82rem;
        background: #f8f9fa;
        border: 1.5px solid var(--db-border);
        border-radius: 10px;
        font-family: 'Segoe UI', sans-serif;
        color: var(--db-text);
        cursor: pointer;
        outline: none;
        font-weight: 500;
        transition: border-color 180ms;
        }

        .db-route-select:focus {
        border-color: var(--db-teal);
        }

        .db-select-arrow {
        position: absolute;
        right: 12px;
        pointer-events: none;
        color: var(--db-text);
        }

        /* ── Page title ─────────────────────────────────────────── */
        .db-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--db-text);
        font-family: 'Segoe UI', sans-serif;
        margin-bottom: 20px;
        }

        /* ── Title row + refresh + date ─────────────────────────── */
        .db-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
        }

        .db-title-row .db-title { margin-bottom: 0; }

        .db-title-tools {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        }

        .db-date-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 30px;
        background: #EAF7F5;
        color: #2e7d72;
        font-size: .86rem;
        font-weight: 700;
        font-family: 'Segoe UI', sans-serif;
        border: 1px solid #CDE9E4;
        white-space: nowrap;
        }

        .db-btn-refresh {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 16px;
        border-radius: 8px;
        background: #fff;
        color: #2e7d72;
        border: 1px solid #CDE9E4;
        font-weight: 700;
        font-size: .86rem;
        font-family: 'Segoe UI', sans-serif;
        cursor: pointer;
        }

        .db-btn-refresh:hover { background: #EAF7F5; }
        .db-btn-refresh.spinning .db-refresh-ico { display:inline-block; animation: dbSpin .7s linear infinite; }
        .db-refresh-ico { font-size: 1rem; line-height: 1; }
        @@keyframes dbSpin { to { transform: rotate(360deg); } }
        .db-updated { font-size: .78rem; color: var(--db-muted); font-family: 'Segoe UI', sans-serif; }

        /* ── Clickable Total Passengers card + breakdown ────────── */
        .db-stat-card--click { cursor: pointer; transition: box-shadow .15s, transform .15s; }
        .db-stat-card--click:hover { box-shadow: 0 6px 18px rgba(59,130,246,.18); transform: translateY(-2px); }
        .db-stat-chevron { margin-left: auto; color: var(--db-muted); font-size: .8rem; }

        .db-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 3000;
        background: rgba(13,28,40,.5);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        }

        .db-modal {
        background: var(--db-white);
        border-radius: 16px;
        width: 100%;
        max-width: 720px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 14px 44px rgba(0,0,0,.28);
        font-family: 'Segoe UI', sans-serif;
        }

        .db-modal-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 18px 22px;
        border-bottom: 1px solid var(--db-border);
        }

        .db-modal-title { font-size: 1.05rem; font-weight: 800; color: var(--db-text); }
        .db-modal-sub { font-size: .8rem; color: var(--db-muted); margin-top: 3px; }

        .db-modal-close {
        border: none;
        background: transparent;
        font-size: 1.6rem;
        line-height: 1;
        color: var(--db-muted);
        cursor: pointer;
        padding: 0 4px;
        }
        .db-modal-close:hover { color: var(--db-text); }

        .db-modal-body { padding: 14px 22px 20px; overflow-y: auto; }

        .db-breakdown-empty { font-size: .85rem; color: var(--db-muted); font-family: 'Segoe UI', sans-serif; }

        .db-breakdown-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
        font-size: .84rem;
        }

        .db-breakdown-table th {
        text-align: left;
        color: var(--db-muted);
        font-weight: 600;
        padding: 8px 10px;
        border-bottom: 1px solid var(--db-border);
        }

        .db-breakdown-table td {
        color: var(--db-text);
        padding: 8px 10px;
        border-bottom: 1px solid #F2F4F7;
        }

        .db-breakdown-table .db-num { text-align: right; }

        /* ── Stat grid ──────────────────────────────────────────── */
        .db-stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 20px;
        }

        .db-stat-card {
        background: var(--db-white);
        border: 1px solid var(--db-border);
        border-radius: var(--db-radius);
        padding: 20px 22px;
        box-shadow: var(--db-shadow);
        }

        .db-stat-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        }

        .db-stat-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        }

        .db-stat-icon--green {
        background: #E8F8EE;
        color: #27AE60;
        }

        .db-stat-icon--red {
        background: #FEECEC;
        color: #E74C3C;
        }

        .db-stat-icon--blue {
        background: #EAF3FF;
        color: #3B82F6;
        }

        .db-stat-icon--pink {
        background: #FDF0F8;
        color: #D63384;
        }

        .db-stat-label {
        font-size: 0.85rem;
        font-family: 'Segoe UI', sans-serif;
        color: var(--db-muted);
        font-weight: 500;
        }

        .db-stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        color: var(--db-text);
        font-family: 'Segoe UI', sans-serif;
        line-height: 1.1;
        text-align: center;
        }

        .db-stat-delta {
        font-size: 0.78rem;
        font-family: 'Segoe UI', sans-serif;
        margin-top: 6px;
        text-align: center;
        }

        .db-stat-delta--up {
        color: #27AE60;
        }

        .db-stat-delta--down {
        color: #E74C3C;
        }

        /* ── Middle row ─────────────────────────────────────────── */
        .db-mid-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
        }

        /* ── Shared card ────────────────────────────────────────── */
        .db-card {
        background: var(--db-white);
        border: 1px solid var(--db-border);
        border-radius: var(--db-radius);
        padding: 20px 22px;
        box-shadow: var(--db-shadow);
        }

        .db-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
        }

        .db-card-icon {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        }

        .db-card-icon--teal {
        background: var(--db-teal-light);
        color: var(--db-teal);
        }

        .db-card-icon--green {
        background: #E8F8EE;
        color: #27AE60;
        }

        .db-card-icon--red {
        background: #FEECEC;
        color: #E74C3C;
        }

        .db-card-icon--orange {
        background: #FEF3E8;
        color: #F4723B;
        }

        .db-card-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--db-text);
        font-family: 'Segoe UI', sans-serif;
        }

        .db-badge {
        font-size: 0.72rem;
        font-weight: 600;
        font-family: 'Segoe UI', sans-serif;
        padding: 3px 10px;
        border-radius: 20px;
        }

        .db-badge--teal {
        background: var(--db-teal-light);
        color: var(--db-teal);
        }

        .db-chart-legend {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-left: auto;
        }

        .db-legend-swatch {
        width: 26px;
        height: 12px;
        border-radius: 3px;
        display: inline-block;
        }

        .db-legend-text {
        font-size: 0.78rem;
        color: var(--db-muted);
        font-family: 'Segoe UI', sans-serif;
        }

        /* ── Chart canvas ───────────────────────────────────────── */
        .db-chart-canvas {
        height: 260px !important;
        width: 100% !important;
        }

        /* ── Map ────────────────────────────────────────────────── */
        .db-card--map {
        display: flex;
        flex-direction: column;
        }

        .db-map-body {
        flex: 1;
        }

        /* Live Leaflet preview + hover "Show more" overlay */
        .db-map-link {
        position: relative;
        display: block;
        height: 280px;
        border-radius: 10px;
        overflow: hidden;
        text-decoration: none;
        }

        .db-map-leaflet {
        position: absolute;
        inset: 0;
        background: #E8EFF7;
        }

        .db-card--map .db-map-legend {
        z-index: 600;
        }

        .db-map-overlay {
        position: absolute;
        inset: 0;
        z-index: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(45, 55, 72, 0);
        opacity: 0;
        transition: opacity 160ms, background 160ms;
        /* Always the click target (sits over the non-interactive map) so the whole
           card reliably navigates to the Fleet Map. */
        pointer-events: auto;
        cursor: pointer;
        }

        .db-map-link:hover .db-map-overlay {
        opacity: 1;
        background: rgba(45, 55, 72, 0.18);
        }

        .db-map-more {
        background: var(--db-white);
        color: var(--db-teal);
        font-family: 'Segoe UI', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 9px 18px;
        border-radius: 20px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .2);
        }

        /* Bus pill markers (same look as the Fleet Map page) */
        .fm-bus-marker {
        background: transparent !important;
        border: none !important;
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .fm-bus-marker span {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 14px;
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        font-family: 'Segoe UI', sans-serif;
        letter-spacing: 0.03em;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .18);
        white-space: nowrap;
        }

        .db-map-placeholder {
        position: relative;
        height: 280px;
        background: #E8EFF7;
        border-radius: 10px;
        overflow: hidden;
        }

        .db-map-grid {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,.35) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.35) 1px, transparent 1px);
        background-size: 40px 40px;
        }

        .db-bus-marker {
        position: absolute;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        font-family: 'Segoe UI', sans-serif;
        color: #fff;
        white-space: nowrap;
        transform: translate(-50%, -50%);
        }

        .db-bus--orange {
        background: #F4723B;
        }

        .db-bus--teal {
        background: #4AADA8;
        }

        .db-bus-dot {
        position: absolute;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 3px solid #fff;
        transform: translate(-50%, -50%);
        box-shadow: 0 0 0 3px rgba(74,173,168,.3);
        }

        .db-map-legend {
        position: absolute;
        top: 12px;
        right: 12px;
        background: #fff;
        border-radius: 8px;
        padding: 10px 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.1);
        font-family: 'Segoe UI', sans-serif;
        }

        .db-map-legend-title {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--db-text);
        margin-bottom: 6px;
        }

        .db-map-legend-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.78rem;
        color: var(--db-text);
        margin-bottom: 4px;
        }

        .db-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
        }

        /* ── Bottom row ─────────────────────────────────────────── */
        .db-bottom-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        }

        .db-card--bottom {
        padding: 18px 20px;
        }

        .db-card-icon-wrap {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
        }

        .db-card-body-text {
        font-size: 0.85rem;
        color: var(--db-muted);
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        line-height: 1.5;
        }

        .db-card-body-text strong {
        color: var(--db-text);
        }

        /* ── Responsive ─────────────────────────────────────────── */
        @@media (max-width: 1100px) {
        .db-stat-grid {
        grid-template-columns: repeat(2, 1fr);
        }

        .db-mid-grid {
        grid-template-columns: 1fr;
        }
        }

        @@media (max-width: 640px) {
        .db-stat-grid {
        grid-template-columns: 1fr;
        }

        .db-bottom-grid {
        grid-template-columns: 1fr;
        }

        .db-topbar {
        flex-direction: column;
        align-items: stretch;
        }
        }
    </style>

    @section TopbarContent {
        @* Single form — sends routeId on every submit *@
        <form id="filterForm" method="get" action="@Url.Action("Index", "Dashboard")" style="display:contents;">

            <div class="db-route-wrap">
                <span class="db-route-label">Route:</span>
                <div class="db-route-select-wrap">
                    <select id="routeSelect" name="routeId" class="db-route-select">
                        <option value="">All Routes</option>
                        @foreach (var route in Model.Routes)
                        {
                            if (route.Selected)
                            {
                                <option value="@route.Value" selected>@route.Text</option>
                            }
                            else
                            {
                                <option value="@route.Value">@route.Text</option>
                            }
                        }
                    </select>
                    <span class="db-select-arrow">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                            <polyline points="6 9 12 15 18 9" />
                        </svg>
                    </span>
                </div>
            </div>

        </form>
    }
